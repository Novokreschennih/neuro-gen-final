---
title: "Калькулятор дохода NeuroGen × SetHubble"
permalink: /calculator/
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="ru" class="scroll-smooth">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }}</title>
    <meta name="robots" content="noindex, nofollow">
    <meta http-equiv="Content-Security-Policy" content="default-src * 'self' 'unsafe-inline' 'unsafe-eval' data: gap: content: blob:; script-src * 'self' 'unsafe-inline' 'unsafe-eval'; style-src * 'self' 'unsafe-inline';">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      body {
        padding-top: 56px;
        background: #050510;
        color: #fff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100vh;
        margin: 0;
      }
      .glass-panel {
        background: rgba(10,10,26,0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 28px;
        padding: 28px;
        margin-bottom: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }
      .section-label {
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9ca3af;
        margin: 0 0 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      /* Sliders */
      .slider-row { margin-bottom: 18px; }
      .slider-row:last-child { margin-bottom: 0; }
      .slider-label {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: 700;
        color: #d1d5db;
        margin-bottom: 8px;
      }
      .slider-label .slider-val { color: #06b6d4; }
      input[type="range"] {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 6px;
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
        outline: none;
        cursor: pointer;
      }
      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
        box-shadow: 0 0 20px rgba(6,182,212,0.3);
      }
      input[type="range"]::-moz-range-thumb {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
      }
      .num-input {
        width: 56px;
        padding: 3px 6px;
        border: 1px solid rgba(255,255,255,0.12);
        border-radius: 6px;
        background: rgba(255,255,255,0.04);
        color: #06b6d4;
        font-size: 12px;
        font-weight: 700;
        text-align: center;
        outline: none;
        -moz-appearance: textfield;
        appearance: textfield;
      }
      .num-input::-webkit-inner-spin-button,
      .num-input::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
      }
      .num-input:focus {
        border-color: #06b6d4;
        box-shadow: 0 0 12px rgba(6,182,212,0.15);
      }

      /* Toggle */
      .toggle-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        cursor: pointer;
        user-select: none;
      }
      .toggle-track {
        width: 44px;
        height: 24px;
        background: rgba(255,255,255,0.1);
        border-radius: 12px;
        position: relative;
        transition: background 0.25s;
        flex-shrink: 0;
      }
      .toggle-track .toggle-knob {
        width: 18px;
        height: 18px;
        background: #6b7280;
        border-radius: 50%;
        position: absolute;
        top: 3px;
        left: 3px;
        transition: all 0.25s;
      }
      #toggle-sh:checked + .toggle-track {
        background: rgba(6,182,212,0.3);
      }
      #toggle-sh:checked + .toggle-track .toggle-knob {
        left: 23px;
        background: #06b6d4;
      }
      #toggle-sh { display: none; }
      .toggle-label {
        font-size: 12px;
        font-weight: 700;
        color: #d1d5db;
      }

      /* Hidden SH block */
      .sh-block { transition: all 0.3s; }
      .sh-block.hidden { display: none; }

      /* Desktop — компактнее */
      @media (min-width: 768px) {
        .inputs-grid {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 16px;
        }
        .glass-panel {
          padding: 20px 24px;
        }
        #results-table {
          font-size: 13px;
        }
        .slider-row {
          margin-bottom: 14px;
        }
        .chart-wrap {
          height: 260px;
        }
      }

      /* Cards */
      .cards-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 12px;
      }
      .card {
        background: rgba(10,10,26,0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid var(--card-border);
        border-radius: 20px;
        padding: 16px;
        cursor: pointer;
        transition: all 0.2s;
        position: relative;
      }
      .card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 32px rgba(0,0,0,0.4);
      }
      .card-active {
        border-color: var(--card-accent) !important;
        box-shadow: 0 0 24px rgba(6,182,212,0.15), inset 0 0 20px var(--card-bg);
        background: var(--card-bg);
      }
      .card-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        margin-bottom: 10px;
      }
      .card-title {
        font-size: 15px;
        font-weight: 900;
        line-height: 1.2;
      }
      .card-subtitle {
        font-size: 10px;
        color: #6b7280;
        margin-top: 1px;
      }
      .card-entry {
        font-size: 10px;
        font-weight: 700;
        color: #9ca3af;
        background: rgba(255,255,255,0.06);
        padding: 3px 10px;
        border-radius: 8px;
        white-space: nowrap;
      }
      .card-section-label {
        font-size: 10px;
        font-weight: 800;
        color: #9ca3af;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin: 10px 0 4px;
      }
      .card-row {
        display: flex;
        justify-content: space-between;
        font-size: 11px;
        padding: 2px 0;
        line-height: 1.5;
      }
      .card-row span:first-child { color: #9ca3af; }
      .card-row span:last-child { color: #d1d5db; font-weight: 600; }
      .card-income { margin-bottom: 2px; }
      .card-total {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: 800;
        padding: 4px 0 2px;
        margin-bottom: 2px;
        border-top: 1px solid rgba(255,255,255,0.06);
        color: #e5e7eb;
      }
      .card-cap-hit {
        font-size: 10px;
        font-weight: 700;
        color: #ef4444;
        margin: 2px 0 6px;
        padding: 2px 6px;
        background: rgba(239,68,68,0.08);
        border-radius: 4px;
        display: inline-block;
      }
      .card-binary span:first-child { color: #22c55e; }
      .card-binary span:last-child { color: #22c55e; font-weight: 800; }
      .card-binary-note {
        font-size: 8px;
        color: #6b7280;
        line-height: 1.3;
        margin-bottom: 6px;
        font-style: italic;
      }
      .card-fee span:last-child { color: #6b7280; }
      .card-divider {
        height: 1px;
        background: rgba(255,255,255,0.08);
        margin: 8px 0;
      }
      .card-net {
        text-align: center;
        padding-top: 4px;
      }
      .card-net-label {
        font-size: 9px;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-weight: 700;
      }
      .card-net-val {
        font-size: 22px;
        font-weight: 900;
        line-height: 1.2;
      }

      @media (min-width: 640px) {
        .cards-grid { grid-template-columns: 1fr 1fr; }
      }
      @media (min-width: 1024px) {
        .cards-grid { grid-template-columns: 1fr 1fr 1fr 1fr; }
      }

      /* CTA */
      .cta-row {
        display: flex;
        flex-direction: column;
        gap: 10px;
        margin-bottom: 20px;
      }
      .btn-main, .btn-second {
        display: block;
        width: 100%;
        font-weight: 900;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 14px 20px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        transition: all 0.2s;
        box-sizing: border-box;
      }
      .btn-main {
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        color: #fff;
      }
      .btn-main:hover { opacity: 0.9; }
      .btn-second {
        background: rgba(255,255,255,0.04);
        color: #d1d5db;
        border: 1px solid rgba(255,255,255,0.12);
      }
      .btn-second:hover {
        background: rgba(255,255,255,0.08);
        border-color: rgba(255,255,255,0.2);
      }
      @media (min-width: 640px) {
        .cta-row {
          flex-direction: row;
        }
        .btn-main, .btn-second {
          flex: 1;
        }
      }

      /* Chart */
      .chart-wrap {
        position: relative;
        height: 300px;
      }

      .hidden { display: none !important; }
    </style>
  </head>
  <body>
    <!-- HEADER -->
    <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 2147483647; background: rgba(5,5,5,0.99); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.1); box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
      <div style="max-width: 1200px; margin: 0 auto; padding: 0 12px; height: 52px; display: flex; align-items: center; justify-content: space-between;">
        <a href="/" style="display: flex; align-items: center; gap: 6px; color: rgba(200,200,200,1); text-decoration: none; font-size: 14px; font-weight: 600; padding: 8px 12px; border-radius: 10px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);">&larr; Назад</a>
        <span style="font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3);">NeuroGen &times; SetHubble</span>
      </div>
    </nav>

    <!-- MAIN -->
    <div id="synergy-calculator" style="max-width: 1200px; margin: 0 auto; padding: 24px 16px 80px;">

      <!-- HERO -->
      <div class="glass-panel" style="text-align: center; border-top: 1px solid rgba(6,182,212,0.2);">
        <div style="font-size: 40px; margin-bottom: 12px;">&#x1F9E0;</div>
        <h1 style="font-size: 24px; font-weight: 900; text-transform: uppercase; letter-spacing: -0.02em; margin: 0 0 8px; background: linear-gradient(135deg, #06b6d4, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1.2;">Калькулятор дохода</h1>
        <p style="color: #9ca3af; font-size: 13px; line-height: 1.6; margin: 0; max-width: 500px; margin-left: auto; margin-right: auto;">Сравните 4 тарифных плана и увидьте, сколько денег сгорает на глубине без Rocket или Shuttle.</p>
      </div>

      <!-- BLOCK A + B: сетка на десктопе -->
      <div class="inputs-grid">

      <!-- BLOCK A: Basic inputs -->
      <div class="glass-panel" style="border-top: 1px solid rgba(6,182,212,0.15);">
        <div class="section-label" style="color: #06b6d4;">&#x1F4B0; Продажи PRO-статуса ($20)</div>

        <div class="slider-row">
          <div class="slider-label">
            <span>Ваши личные продажи (1-й уровень)</span>
            <div style="display:flex;align-items:center;gap:6px;"><input type="number" id="num-personal" class="num-input" value="10" min="1" max="1000"><span class="slider-val" id="val-personal">10</span></div>
          </div>
          <input type="range" id="inp-personal" min="1" max="1000" value="10">
        </div>

        <div class="slider-row">
          <div class="slider-label">
            <span>Продажи каждого вашего партнёра</span>
            <div style="display:flex;align-items:center;gap:6px;"><input type="number" id="num-partner" class="num-input" value="3" min="1" max="1000"><span class="slider-val" id="val-partner">3</span></div>
          </div>
          <input type="range" id="inp-partner" min="1" max="1000" value="3">
        </div>

        <div class="slider-row" style="margin-bottom: 0;">
          <div class="slider-label">
            <span>Индекс дупликации сети</span>
            <div style="display:flex;align-items:center;gap:6px;"><input type="number" id="num-duplication" class="num-input" value="100" min="1" max="200"><span class="slider-val" id="val-duplication">100%</span></div>
          </div>
          <input type="range" id="inp-duplication" min="1" max="200" value="100">
          <div style="display: flex; justify-content: space-between; font-size: 10px; color: #6b7280; margin-top: 4px;">
            <span>1% (минимальное повторение)</span>
            <span>200% (удвоение)</span>
          </div>
        </div>
      </div>

      <!-- BLOCK B: SetHubble toggle + conditional sliders -->
      <div class="glass-panel" style="border-top: 1px solid rgba(168,85,247,0.12);">
        <div class="section-label" style="color: #a855f7;">&#x1F680; Транзакционная рента SetHubble</div>

        <label class="toggle-wrap">
          <input type="checkbox" id="toggle-sh" checked>
          <div class="toggle-track"><span class="toggle-knob"></span></div>
          <span class="toggle-label">Учитывать покупки тарифов SetHubble внутри сети</span>
        </label>

        <div id="sh-block">
          <div class="slider-row">
            <div class="slider-label">
              <span>% сети купит <strong style="color:#f59e0b;">Rocket</strong> ($110)</span>
              <div style="display:flex;align-items:center;gap:6px;"><input type="number" id="num-rocket" class="num-input" value="5" min="1" max="100"><span class="slider-val" id="val-rocket">5%</span></div>
            </div>
            <input type="range" id="inp-rocket" min="1" max="100" value="5">
          </div>

          <div class="slider-row" style="margin-bottom: 0;">
            <div class="slider-label">
              <span>% сети купит <strong style="color:#a855f7;">Shuttle</strong> ($350)</span>
              <div style="display:flex;align-items:center;gap:6px;"><input type="number" id="num-shuttle" class="num-input" value="2" min="1" max="100"><span class="slider-val" id="val-shuttle">2%</span></div>
            </div>
            <input type="range" id="inp-shuttle" min="1" max="100" value="2">
            <div style="font-size: 10px; color: #6b7280; margin-top: 4px;">
              Каждый покупатель Shuttle даёт баллы для бинарного бонуса (1000 баллов = $100)
            </div>
          </div>
        </div>
      </div>
      </div>

      <!-- SEPARATOR -->
      <div style="text-align: center; margin: 4px 0 16px; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(255,255,255,0.15);">&#x2500;&#x2500;&#x2500;&#x2500; Сравнение тарифов &#x2500;&#x2500;&#x2500;&#x2500;</div>

      <!-- CARDS (rendered by JS) -->
      <div id="results-table" style="margin-bottom: 16px;"></div>

      <!-- CTA -->
      <div class="cta-row">
        <a id="cta-button-pro" href="#" class="btn-main">&#x1F525; Купить PRO-статус</a>
        <a id="cta-button-sh" href="https://sethubble.com/ru/p_qdr" class="btn-second" target="_blank">&#x1F680; Тарифы SetHubble</a>
      </div>

      <!-- CHART -->
      <div class="glass-panel" style="border-top: 1px solid rgba(6,182,212,0.1);">
        <div class="section-label">&#x1F4CA; Сравнение дохода</div>
        <div class="chart-wrap">
          <canvas id="income-chart"></canvas>
        </div>
      </div>

      <!-- FOOTER NOTE -->
      <div class="glass-panel" style="text-align: center; border-top: 1px solid rgba(255,255,255,0.05); padding: 20px; background: rgba(5,5,15,0.5);">
        <p style="font-size: 11px; color: #6b7280; line-height: 1.6; margin: 0;">
          &#x2139;&#xFE0F; Нажмите на любую карточку, чтобы увидеть следующий шаг апгрейда.<br>
          Лимиты (Cap) применяются только к пассивному доходу со 2-10 уровней. Доход с 1-го уровня не ограничен.
        </p>
      </div>

    </div>

    <script>
    try {
      var t = sessionStorage.getItem('neurogen_token');
      if (t) {
        var p = t.split('.')[1].replace(/-/g,'+').replace(/_/g,'/');
        var pad = p.length % 4;
        if (pad) p += '='.repeat(4 - pad);
        var d = JSON.parse(atob(p));
        window.__CALC_USER = {
          xp: parseInt(d.xp) || 0,
          partnerId: d.sh_user_id || d.inviter_sh_id || '1123',
          shRefUrl: d.sh_ref_url || '',
        };
      }
    } catch(e) {}
    </script>
    <script src="/js/synergy-calculator.js"></script>
  </body>
</html>
