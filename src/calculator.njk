---
title: "Калькулятор дохода NeuroGen × SetHubble"
permalink: /calculator/
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="ru" class="scroll-smooth">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }}</title>
    <meta name="robots" content="noindex, nofollow">
    <meta http-equiv="Content-Security-Policy" content="default-src * 'self' 'unsafe-inline' 'unsafe-eval' data: gap: content: blob:; script-src * 'self' 'unsafe-inline' 'unsafe-eval'; style-src * 'self' 'unsafe-inline';">
    <link rel="stylesheet" href="/css/style.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
      body {
        padding-top: 56px;
        background: #050510;
        color: #fff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100vh;
        margin: 0;
      }
      .glass-panel {
        background: rgba(10,10,26,0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 28px;
        padding: 28px;
        margin-bottom: 20px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }
      .section-label {
        font-size: 12px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9ca3af;
        margin: 0 0 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }

      /* Sliders */
      .slider-row { margin-bottom: 18px; }
      .slider-row:last-child { margin-bottom: 0; }
      .slider-label {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: 700;
        color: #d1d5db;
        margin-bottom: 8px;
      }
      .slider-label .slider-val { color: #06b6d4; }
      input[type="range"] {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 6px;
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
        outline: none;
        cursor: pointer;
      }
      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
        box-shadow: 0 0 20px rgba(6,182,212,0.3);
      }
      input[type="range"]::-moz-range-thumb {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
      }

      /* Toggle */
      .toggle-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 16px;
        cursor: pointer;
        user-select: none;
      }
      .toggle-track {
        width: 44px;
        height: 24px;
        background: rgba(255,255,255,0.1);
        border-radius: 12px;
        position: relative;
        transition: background 0.25s;
        flex-shrink: 0;
      }
      .toggle-track .toggle-knob {
        width: 18px;
        height: 18px;
        background: #6b7280;
        border-radius: 50%;
        position: absolute;
        top: 3px;
        left: 3px;
        transition: all 0.25s;
      }
      #toggle-sh:checked + .toggle-track {
        background: rgba(6,182,212,0.3);
      }
      #toggle-sh:checked + .toggle-track .toggle-knob {
        left: 23px;
        background: #06b6d4;
      }
      #toggle-sh { display: none; }
      .toggle-label {
        font-size: 12px;
        font-weight: 700;
        color: #d1d5db;
      }

      /* Hidden SH block */
      .sh-block { transition: all 0.3s; }
      .sh-block.hidden { display: none; }

      /* Table */
      .table-wrap {
        overflow-x: auto;
        margin-bottom: 20px;
      }
      #results-table {
        width: 100%;
        border-collapse: separate;
        border-spacing: 0;
        font-size: 12px;
        min-width: 600px;
      }
      #results-table .tr-header .tc {
        padding: 14px 10px 10px;
        font-weight: 900;
        font-size: 13px;
        text-align: center;
        vertical-align: top;
        line-height: 1.4;
        border-bottom: 2px solid rgba(255,255,255,0.08);
      }
      #results-table .tr-row .tc {
        padding: 10px;
        text-align: center;
        vertical-align: middle;
        border-bottom: 1px solid rgba(255,255,255,0.04);
        transition: background 0.15s;
        cursor: pointer;
      }
      #results-table .tr-row .tc.th {
        text-align: left;
        color: #9ca3af;
        font-weight: 700;
        font-size: 11px;
        white-space: nowrap;
        padding-left: 4px;
        cursor: default;
        min-width: 120px;
      }
      #results-table .tr-net .tc {
        border-top: 2px solid rgba(255,255,255,0.08);
        border-bottom: none;
        padding: 14px 10px;
      }
      #results-table .tc.col-active {
        background: rgba(6,182,212,0.08);
        box-shadow: inset 0 0 20px rgba(6,182,212,0.06);
      }
      #results-table .tc.col-header.col-active {
        background: rgba(6,182,212,0.12);
      }
      #results-table .tc:hover:not(.th) {
        background: rgba(255,255,255,0.03);
      }
      .gross-val { color: #d1d5db; font-weight: 700; }
      .missed-val { color: #ef4444; font-weight: 900; }
      .bonus-val { color: #22c55e; font-weight: 700; }
      .net-val { font-size: 14px; font-weight: 900; }
      .cell-net-warn .net-val { color: #f59e0b; }
      .cell-net-ok .net-val { color: #22c55e; }
      .depth-warn { color: #f87171; font-size: 11px; }
      .depth-ok { color: #22c55e; font-size: 11px; }
      .capped { color: #f87171; }

      /* CTA */
      .btn-main {
        display: block;
        width: 100%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        color: #fff;
        font-weight: 900;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 16px 20px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .btn-main:hover { opacity: 0.9; }
      .btn-disabled {
        display: block;
        width: 100%;
        background: rgba(255,255,255,0.05);
        color: #6b7280;
        font-weight: 900;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 16px 20px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        cursor: default;
        pointer-events: none;
      }

      /* Chart */
      .chart-wrap {
        position: relative;
        height: 300px;
      }

      .hidden { display: none !important; }
    </style>
  </head>
  <body>
    <!-- HEADER -->
    <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 2147483647; background: rgba(5,5,5,0.99); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.1); box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
      <div style="max-width: 1024px; margin: 0 auto; padding: 0 12px; height: 52px; display: flex; align-items: center; justify-content: space-between;">
        <a href="/" style="display: flex; align-items: center; gap: 6px; color: rgba(200,200,200,1); text-decoration: none; font-size: 14px; font-weight: 600; padding: 8px 12px; border-radius: 10px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);">&larr; Назад</a>
        <span style="font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3);">NeuroGen &times; SetHubble</span>
      </div>
    </nav>

    <!-- MAIN -->
    <div id="synergy-calculator" style="max-width: 1024px; margin: 0 auto; padding: 24px 16px 80px;">

      <!-- HERO -->
      <div class="glass-panel" style="text-align: center; border-top: 1px solid rgba(6,182,212,0.2);">
        <div style="font-size: 40px; margin-bottom: 12px;">&#x1F9E0;</div>
        <h1 style="font-size: 24px; font-weight: 900; text-transform: uppercase; letter-spacing: -0.02em; margin: 0 0 8px; background: linear-gradient(135deg, #06b6d4, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1.2;">Калькулятор дохода</h1>
        <p style="color: #9ca3af; font-size: 13px; line-height: 1.6; margin: 0; max-width: 500px; margin-left: auto; margin-right: auto;">Сравните 4 тарифных плана и увидьте, сколько денег сгорает на глубине без Rocket или Shuttle.</p>
      </div>

      <!-- BLOCK A: Basic inputs -->
      <div class="glass-panel" style="border-top: 1px solid rgba(6,182,212,0.15);">
        <div class="section-label" style="color: #06b6d4;">&#x1F4B0; Продажи PRO-статуса ($20)</div>

        <div class="slider-row">
          <div class="slider-label">
            <span>Ваши личные продажи (1-й уровень)</span>
            <span class="slider-val" id="val-personal">10</span>
          </div>
          <input type="range" id="inp-personal" min="1" max="1000" value="10">
        </div>

        <div class="slider-row">
          <div class="slider-label">
            <span>Продажи каждого вашего партнёра</span>
            <span class="slider-val" id="val-partner">3</span>
          </div>
          <input type="range" id="inp-partner" min="1" max="1000" value="3">
        </div>

        <div class="slider-row" style="margin-bottom: 0;">
          <div class="slider-label">
            <span>Индекс дупликации сети</span>
            <span class="slider-val" id="val-duplication">100%</span>
          </div>
          <input type="range" id="inp-duplication" min="1" max="200" value="100">
          <div style="display: flex; justify-content: space-between; font-size: 10px; color: #6b7280; margin-top: 4px;">
            <span>1% (минимальное повторение)</span>
            <span>200% (удвоение)</span>
          </div>
        </div>
      </div>

      <!-- BLOCK B: SetHubble toggle + conditional sliders -->
      <div class="glass-panel" style="border-top: 1px solid rgba(168,85,247,0.12);">
        <div class="section-label" style="color: #a855f7;">&#x1F680; Транзакционная рента SetHubble</div>

        <label class="toggle-wrap">
          <input type="checkbox" id="toggle-sh" checked>
          <div class="toggle-track"><span class="toggle-knob"></span></div>
          <span class="toggle-label">Учитывать покупки тарифов SetHubble внутри сети</span>
        </label>

        <div id="sh-block">
          <div class="slider-row">
            <div class="slider-label">
              <span>% сети купит <strong style="color:#f59e0b;">Rocket</strong> ($110)</span>
              <span class="slider-val" id="val-rocket">5%</span>
            </div>
            <input type="range" id="inp-rocket" min="1" max="100" value="5">
          </div>

          <div class="slider-row" style="margin-bottom: 0;">
            <div class="slider-label">
              <span>% сети купит <strong style="color:#a855f7;">Shuttle</strong> ($350)</span>
              <span class="slider-val" id="val-shuttle">2%</span>
            </div>
            <input type="range" id="inp-shuttle" min="1" max="100" value="2">
            <div style="font-size: 10px; color: #6b7280; margin-top: 4px;">
              Каждый покупатель Shuttle даёт баллы для бинарного бонуса (1000 баллов = $100)
            </div>
          </div>
        </div>
      </div>

      <!-- SEPARATOR -->
      <div style="text-align: center; margin: 4px 0 16px; font-size: 10px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.15em; color: rgba(255,255,255,0.15);">&#x2500;&#x2500;&#x2500;&#x2500; Сравнение тарифов &#x2500;&#x2500;&#x2500;&#x2500;</div>

      <!-- TABLE (rendered by JS) -->
      <div class="table-wrap glass-panel" style="padding: 16px; border-top: 1px solid rgba(6,182,212,0.1);">
        <div id="results-table"></div>
      </div>

      <!-- CTA -->
      <a id="cta-button" href="#" class="btn-main" style="margin-bottom: 20px;">&#x1F525; Купить PRO за $20</a>

      <!-- CHART -->
      <div class="glass-panel" style="border-top: 1px solid rgba(6,182,212,0.1);">
        <div class="section-label">&#x1F4CA; Сравнение дохода</div>
        <div class="chart-wrap">
          <canvas id="income-chart"></canvas>
        </div>
      </div>

      <!-- FOOTER NOTE -->
      <div class="glass-panel" style="text-align: center; border-top: 1px solid rgba(255,255,255,0.05); padding: 20px; background: rgba(5,5,15,0.5);">
        <p style="font-size: 11px; color: #6b7280; line-height: 1.6; margin: 0;">
          &#x2139;&#xFE0F; Нажмите на любую колонку в таблице, чтобы увидеть следующий шаг апгрейда.<br>
          Лимиты (Cap) применяются только к пассивному доходу со 2-10 уровней. Доход с 1-го уровня не ограничен.
        </p>
      </div>

    </div>

    <script src="/js/synergy-calculator.js"></script>
  </body>
</html>
