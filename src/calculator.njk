      <div class="glass-panel" style="opacity: 0.88; border-top: 1px solid rgba(255,255,255,0.05);">
        <div class="section-label" style="font-size: 11px;">&#x1F680; Тариф SetHubble <span style="color: #6b7280; font-weight: 400; text-transform: none; letter-spacing: 0;">(влияет на глубину комиссий)</span></div>

        <div class="radio-group">
          <label class="radio-option active" id="label-tariff-plane">
            <input type="radio" name="tariff" id="tariff-plane" value="plane" checked>
            <span class="radio-dot"><span class="radio-dot-inner"></span></span>
