    <style>
      body {
        padding-top: 56px;
        background: #050510;
        color: #fff;
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        min-height: 100vh;
        margin: 0;
      }
      .glass-panel {
        background: rgba(10,10,26,0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 32px;
        padding: 32px;
        margin-bottom: 24px;
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }
      .glass-panel-thin {
        background: rgba(10,10,26,0.4);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 24px;
      }
      .section-label {
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: #9ca3af;
        margin: 0 0 20px;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      .section-label .badge {
        font-size: 9px;
        background: rgba(6,182,212,0.15);
        color: #06b6d4;
        padding: 2px 10px;
        border-radius: 20px;
        letter-spacing: 0.05em;
      }

      /* Radio cards */
      .radio-group {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }
      .radio-option {
        flex: 1;
        min-width: 180px;
        cursor: pointer;
        background: rgba(0,0,0,0.35);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        padding: 16px 20px;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        gap: 12px;
        user-select: none;
      }
      .radio-option:hover {
        border-color: rgba(255,255,255,0.15);
        background: rgba(0,0,0,0.45);
      }
      .radio-option.active {
        border-color: #06b6d4;
        background: rgba(6,182,212,0.08);
        box-shadow: 0 0 20px rgba(6,182,212,0.08);
      }
      .radio-option input[type="radio"] {
        display: none;
      }
      .radio-dot {
        width: 16px;
        height: 16px;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,0.2);
        flex-shrink: 0;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .radio-dot-inner {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #06b6d4;
        opacity: 0;
        transition: opacity 0.2s;
      }
      .radio-option.active .radio-dot {
        border-color: #06b6d4;
      }
      .radio-option.active .radio-dot-inner {
        opacity: 1;
      }
      .radio-option .radio-title {
        font-size: 14px;
        font-weight: 700;
        color: #e5e7eb;
      }
      .radio-option .radio-sub {
        font-size: 11px;
        color: #6b7280;
        margin-top: 2px;
      }
      .radio-option.active .radio-title {
        color: #06b6d4;
      }
      .radio-option.disabled-option {
        opacity: 0.5;
        pointer-events: none;
      }

      /* Coins toggle */
      .coins-bar {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 16px;
        padding-top: 16px;
        border-top: 1px solid rgba(255,255,255,0.06);
        flex-wrap: wrap;
      }
      .coins-bar-label {
        font-size: 12px;
        font-weight: 600;
        color: #9ca3af;
      }
      .coins-btn {
        cursor: pointer;
        background: rgba(0,0,0,0.35);
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 10px;
        padding: 6px 16px;
        font-size: 12px;
        font-weight: 600;
        color: #9ca3af;
        transition: all 0.2s;
        user-select: none;
      }
      .coins-btn.active {
        border-color: #f59e0b;
        color: #f59e0b;
        background: rgba(245,158,11,0.1);
      }
      .coins-btn.disabled {
        opacity: 0.3;
        pointer-events: none;
      }
      .coins-btn input { display: none; }
      .coins-result {
        font-size: 14px;
        font-weight: 900;
        color: #22c55e;
        margin-left: auto;
      }

      /* Sliders */
      .slider-row {
        margin-bottom: 20px;
      }
      .slider-row:last-child {
        margin-bottom: 0;
      }
      .slider-label {
        display: flex;
        justify-content: space-between;
        font-size: 12px;
        font-weight: 700;
        color: #d1d5db;
        margin-bottom: 8px;
      }
      .slider-label .slider-val {
        color: #06b6d4;
      }
      input[type="range"] {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 6px;
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
        outline: none;
        cursor: pointer;
      }
      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
        box-shadow: 0 0 20px rgba(6,182,212,0.3);
      }
      input[type="range"]::-moz-range-thumb {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
      }
      .slider-hint {
        display: flex;
        justify-content: space-between;
        font-size: 10px;
        color: #6b7280;
        margin-top: 4px;
      }

      /* Warning */
      .warning-block {
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.25);
        border-radius: 12px;
        padding: 12px 16px;
        font-size: 12px;
        color: #f87171;
        margin-top: 12px;
        line-height: 1.5;
      }

      /* Stats grid */
      .stats-grid {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        margin-bottom: 20px;
      }
      .stat-card {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 24px;
        padding: 20px;
        text-align: center;
      }
      .stat-card .stat-icon {
        font-size: 24px;
        margin-bottom: 6px;
      }
      .stat-card .stat-val {
        font-size: 1.6rem;
        font-weight: 900;
        color: #06b6d4;
      }
      .stat-card .stat-label {
        font-size: 9px;
        color: #6b7280;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        margin-top: 4px;
      }
      .stat-card.purple .stat-val { color: #a855f7; }
      .stat-card.amber .stat-val { color: #f59e0b; }
      @media (max-width: 480px) {
        .stats-grid { grid-template-columns: 1fr; }
        .stat-card .stat-val { font-size: 1.3rem; }
        .radio-group { flex-direction: column; }
        .radio-option { min-width: auto; }
      }

      /* Income card */
      .income-card {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 20px;
        padding: 20px;
        margin-bottom: 16px;
      }
      .income-row {
        display: flex;
        justify-content: space-between;
        font-size: 13px;
        padding: 6px 0;
        color: #d1d5db;
      }
      .income-row .inc-val {
        font-weight: 700;
      }
      .income-total {
        display: flex;
        justify-content: space-between;
        font-size: 18px;
        font-weight: 900;
        padding: 12px 0 0;
        margin-top: 8px;
        border-top: 1px solid rgba(255,255,255,0.1);
        color: #22c55e;
      }

      /* Missed blocks */
      .missed-block {
        background: linear-gradient(135deg, rgba(239,68,68,0.1), transparent);
        border: 1px solid rgba(239,68,68,0.3);
        border-radius: 24px;
        padding: 24px;
        margin-bottom: 16px;
      }
      .missed-block h3 {
        font-size: 16px;
        font-weight: 900;
        margin: 0 0 4px;
        text-transform: uppercase;
        color: #f87171;
      }
      .missed-block .big-loss {
        font-size: 28px;
        font-weight: 900;
        color: #ef4444;
      }
      .missed-block p {
        font-size: 12px;
        color: #9ca3af;
        margin: 6px 0 0;
        line-height: 1.5;
      }
      .missed-block-sm {
        background: rgba(245,158,11,0.06);
        border: 1px solid rgba(245,158,11,0.25);
        border-radius: 16px;
        padding: 16px 20px;
        margin-bottom: 16px;
      }
      .missed-block-sm h4 {
        font-size: 13px;
        font-weight: 900;
        margin: 0 0 2px;
        color: #fbbf24;
      }
      .missed-block-sm .loss-val {
        font-size: 20px;
        font-weight: 900;
        color: #f59e0b;
      }

      /* Optimal */
      .optimal-block {
        background: rgba(34,197,94,0.06);
        border: 1px solid rgba(34,197,94,0.25);
        border-radius: 16px;
        padding: 20px;
        text-align: center;
        margin-bottom: 16px;
        font-size: 15px;
        font-weight: 700;
        color: #22c55e;
      }

      /* CTA */
      .btn-main {
        display: block;
        width: 100%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        color: #fff;
        font-weight: 900;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 16px 20px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .btn-main:hover { opacity: 0.9; }
      .btn-disabled {
        display: block;
        width: 100%;
        background: rgba(255,255,255,0.05);
        color: #6b7280;
        font-weight: 900;
        font-size: 13px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 16px 20px;
        border-radius: 16px;
        text-align: center;
        text-decoration: none;
        cursor: default;
        pointer-events: none;
      }

      .hidden { display: none !important; }

      /* Chart */
      .chart-wrap {
        position: relative;
        height: 280px;
      }

      /* Details block */
      details.glass-panel summary {
        cursor: pointer;
        font-size: 13px;
        font-weight: 900;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: #06b6d4;
        outline: none;
        list-style: none;
        display: flex;
        align-items: center;
        gap: 8px;
      }
      details.glass-panel summary::-webkit-details-marker {
        display: none;
      }
      details.glass-panel summary::after {
        content: '\25BC';
        font-size: 10px;
        color: #6b7280;
        transition: transform 0.2s;
      }
      details.glass-panel[open] summary::after {
        transform: rotate(180deg);
      }
      .details-content {
        margin-top: 16px;
        font-size: 13px;
        line-height: 1.7;
        color: #d1d5db;
      }
      .details-content .rate-table {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 8px 24px;
        margin: 12px 0;
        padding: 12px 16px;
        background: rgba(0,0,0,0.3);
        border-radius: 12px;
        font-size: 12px;
      }
      .details-content .rate-table .rt-row {
        display: flex;
        justify-content: space-between;
        padding: 4px 0;
        border-bottom: 1px solid rgba(255,255,255,0.04);
      }
      .details-content .rate-table .rt-row:last-child {
        border-bottom: none;
      }
      .details-content .rate-table .rt-label { color: #9ca3af; }
      .details-content .rate-table .rt-val { color: #06b6d4; font-weight: 700; }
      .details-content .highlight { color: #fbbf24; font-weight: 700; }
      .details-content .highlight-cyan { color: #06b6d4; font-weight: 700; }

      /* Explanation block */
      .explain-panel p {
        font-size: 13px;
        line-height: 1.7;
        color: #d1d5db;
        margin: 0 0 12px;
      }
      .explain-panel p:last-child { margin: 0; }
      .explain-panel .big-num {
        color: #22c55e;
        font-weight: 900;
      }
    </style>
  </head>
  <body>
    <!-- HEADER -->
    <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 2147483647; background: rgba(5,5,5,0.99); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.1); box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
      <div style="max-width: 1024px; margin: 0 auto; padding: 0 12px; height: 52px; display: flex; align-items: center; justify-content: space-between;">
        <a href="/" style="display: flex; align-items: center; gap: 6px; color: rgba(200,200,200,1); text-decoration: none; font-size: 14px; font-weight: 600; padding: 8px 12px; border-radius: 10px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);">&larr; Назад</a>
        <span style="font-size: 11px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3);">NeuroGen &times; SetHubble</span>
