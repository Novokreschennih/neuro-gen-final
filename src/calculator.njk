---
title: "Калькулятор дохода NeuroGen × SetHubble"
permalink: /calculator/
eleventyExcludeFromCollections: true

---
<!DOCTYPE html>
<html lang="ru" class="scroll-smooth">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>{{ title }}</title>
    <meta name="description" content="Калькулятор синергии NeuroGen PRO и SetHubble Rocket — узнайте, сколько вы заработаете на ИИ-ботах и как один уровень может стоить вам состояния.">
    <meta name="robots" content="noindex, nofollow">
    <meta http-equiv="Content-Security-Policy" content="default-src * 'self' 'unsafe-inline' 'unsafe-eval' data: gap: content: blob:; script-src * 'self' 'unsafe-inline' 'unsafe-eval'; style-src * 'self' 'unsafe-inline';">
    <link rel="stylesheet" href="/css/style.css">
    <style>
      .glass-panel {
        background: rgba(10,10,26,0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.08);
        box-shadow: 0 8px 32px rgba(0,0,0,0.3);
      }
      .glass-panel-darker {
        background: rgba(5,5,15,0.8);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255,255,255,0.06);
      }
      input[type="range"] {
        -webkit-appearance: none;
        appearance: none;
        width: 100%;
        height: 6px;
        background: rgba(255,255,255,0.1);
        border-radius: 3px;
        outline: none;
        cursor: pointer;
      }
      input[type="range"]::-webkit-slider-thumb {
        -webkit-appearance: none;
        appearance: none;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
        box-shadow: 0 0 20px rgba(6,182,212,0.3);
      }
      input[type="range"]::-moz-range-thumb {
        width: 22px;
        height: 22px;
        border-radius: 50%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        border: 2px solid rgba(255,255,255,0.3);
        cursor: pointer;
      }
      .btn-main {
        display: block;
        width: 100%;
        background: linear-gradient(135deg, #06b6d4, #8b5cf6);
        color: #fff;
        font-weight: 900;
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 14px 20px;
        border-radius: 14px;
        text-align: center;
        text-decoration: none;
        transition: opacity 0.2s;
      }
      .btn-main:hover { opacity: 0.9; }
      .cmp-card {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 16px;
        padding: 20px;
      }
      .stat-card {
        background: rgba(0,0,0,0.4);
        border: 1px solid rgba(255,255,255,0.06);
        border-radius: 24px;
        padding: 24px;
        text-align: center;
      }
      .stat-value { font-size: 2rem; font-weight: 900; }
      .stat-label { font-size: 10px; color: #6b7280; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
      @media (max-width: 640px) {
        .stat-value { font-size: 1.5rem; }
        .cmp-grid { grid-template-columns: 1fr !important; }
      }
    </style>
  </head>
  <body class="relative" style="padding-top: 56px; background: #050510; color: #fff; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; min-height: 100vh;">
    <!-- HEADER -->
    <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 2147483647; background: rgba(5,5,5,0.99); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid rgba(255,255,255,0.1); box-shadow: 0 4px 20px rgba(0,0,0,0.5);">
      <div style="max-width: 1024px; margin: 0 auto; padding: 0 12px; height: 52px; display: flex; align-items: center; justify-content: space-between;">
        <a href="/" style="display: flex; align-items: center; gap: 6px; color: rgba(200,200,200,1); text-decoration: none; font-size: 14px; font-weight: 600; padding: 8px 12px; border-radius: 10px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.15);">← Назад</a>
        <span style="font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.3);">NeuroGen × SetHubble</span>
      </div>
    </nav>

    <!-- MAIN CONTENT -->
    <div id="synergy-calculator" style="max-width: 1024px; margin: 0 auto; padding: 24px 16px 80px;">

      <!-- HERO -->
      <div class="glass-panel" style="border-radius: 32px; padding: 40px 32px; text-align: center; margin-bottom: 32px; border-top: 1px solid rgba(6,182,212,0.2);">
        <div style="font-size: 48px; margin-bottom: 16px;">🧮</div>
        <h1 style="font-size: 28px; font-weight: 900; text-transform: uppercase; letter-spacing: -0.02em; margin: 0 0 8px; background: linear-gradient(135deg, #06b6d4, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Калькулятор дохода</h1>
        <p style="color: #9ca3af; font-size: 14px; line-height: 1.6; margin: 0; max-width: 500px; margin-left: auto; margin-right: auto;">Узнайте, сколько вы заработаете на ИИ-ботах и как 1 недополученный уровень может стоить вам состояния.</p>
      </div>

      <!-- BLOCK 1: INPUTS -->
      <div class="glass-panel" style="border-radius: 32px; padding: 32px; margin-bottom: 24px; border-top: 1px solid rgba(255,255,255,0.08);">
        <h2 style="font-size: 14px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af; margin: 0 0 24px;">📊 Параметры вашей сети</h2>

        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px 32px;">
          <div>
            <label style="display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: #d1d5db; margin-bottom: 8px;">
              <span>Лично приглашено</span>
              <span id="syn-start-val" style="color: #06b6d4;">3</span>
            </label>
            <input type="range" id="syn-start" min="1" max="50" value="3" data-suffix="">
          </div>
          <div>
            <label style="display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: #d1d5db; margin-bottom: 8px;">
              <span>Шаг (каждый приводит)</span>
              <span id="syn-step-val" style="color: #06b6d4;">3</span>
            </label>
            <input type="range" id="syn-step" min="2" max="10" value="3" data-suffix="">
          </div>
          <div>
            <label style="display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: #d1d5db; margin-bottom: 8px;">
              <span>Конверсия в NeuroGen PRO ($20)</span>
              <span id="syn-conv-pro-val" style="color: #a855f7;">10%</span>
            </label>
            <input type="range" id="syn-conv-pro" min="1" max="50" value="10" data-suffix="%">
          </div>
          <div>
            <label style="display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: #d1d5db; margin-bottom: 8px;">
              <span>Конверсия в SetHubble Rocket ($110)</span>
              <span id="syn-conv-rocket-val" style="color: #f59e0b;">2%</span>
            </label>
            <input type="range" id="syn-conv-rocket" min="0" max="20" value="2" data-suffix="%">
          </div>
        </div>

        <div style="margin-top: 28px; padding-top: 24px; border-top: 1px solid rgba(255,255,255,0.06);">
          <label style="display: flex; justify-content: space-between; font-size: 12px; font-weight: 700; color: #d1d5db; margin-bottom: 8px;">
            <span>🎯 Коэффициент реалистичности</span>
            <span id="syn-realism-val" style="color: #22c55e;">100%</span>
          </label>
          <input type="range" id="syn-realism" min="1" max="100" value="100" data-suffix="%">
          <div style="display: flex; justify-content: space-between; font-size: 10px; color: #6b7280; margin-top: 4px;">
            <span>1% (пессимист)</span>
            <span>100% (идеал)</span>
          </div>
        </div>
      </div>

      <!-- BLOCK 2: NETWORK -->
      <div class="glass-panel" style="border-radius: 32px; padding: 32px; margin-bottom: 24px; border-top: 1px solid rgba(6,182,212,0.15);">
        <h2 style="font-size: 14px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af; margin: 0 0 20px;">👥 Ваша сеть (10 уровней)</h2>
        <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 16px;">
          <div class="stat-card">
            <div class="stat-label">Всего в сети</div>
            <div id="syn-network-total" class="stat-value" style="color: #06b6d4;">0</div>
          </div>
          <div class="stat-card" style="border-top: 2px solid rgba(168,85,247,0.4); background: rgba(168,85,247,0.05);">
            <div class="stat-label" style="color: rgba(168,85,247,0.7);">Купят PRO ($20)</div>
            <div id="syn-network-pro" class="stat-value" style="color: #a855f7;">0</div>
          </div>
          <div class="stat-card" style="border-top: 2px solid rgba(245,158,11,0.4); background: rgba(245,158,11,0.05);">
            <div class="stat-label" style="color: rgba(245,158,11,0.7);">Купят Rocket ($110)</div>
            <div id="syn-network-rocket" class="stat-value" style="color: #f59e0b;">0</div>
          </div>
        </div>
      </div>

      <!-- BLOCK 3: COMPARISON -->
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 24px;" class="cmp-grid">
        <!-- PLANE -->
        <div class="glass-panel" style="border-radius: 32px; padding: 32px; border-top: 1px solid rgba(156,163,175,0.2);">
          <div style="font-size: 36px; margin-bottom: 8px;">✈️</div>
          <h3 style="font-size: 16px; font-weight: 900; text-transform: uppercase; margin: 0 0 4px; color: #9ca3af;">Plane</h3>
          <p style="font-size: 10px; color: #6b7280; margin: 0 0 20px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Бесплатный тариф SetHubble</p>

          <div class="cmp-card" style="margin-bottom: 12px;">
            <div style="display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; margin-bottom: 4px;">
              <span>Доход с PRO</span>
              <span style="color: #6b7280;">(до 3 ур.)</span>
            </div>
            <div id="syn-plane-pro" style="font-size: 24px; font-weight: 900; color: #a855f7;">$0</div>
          </div>
          <div class="cmp-card" style="margin-bottom: 16px;">
            <div style="display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; margin-bottom: 4px;">
              <span>Доход с Rocket</span>
              <span style="color: #6b7280;">(до 3 ур.)</span>
            </div>
            <div id="syn-plane-rocket" style="font-size: 24px; font-weight: 900; color: #f59e0b;">$0</div>
          </div>
          <div style="border-top: 1px solid rgba(255,255,255,0.08); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
            <span style="font-size: 12px; font-weight: 700; color: #9ca3af; text-transform: uppercase;">Итого:</span>
            <span id="syn-plane-total" style="font-size: 28px; font-weight: 900; color: #d1d5db;">$0</span>
          </div>
        </div>

        <!-- ROCKET -->
        <div class="glass-panel" style="border-radius: 32px; padding: 32px; border-top: 2px solid rgba(6,182,212,0.4); background: rgba(6,182,212,0.03); position: relative; overflow: hidden;">
          <div style="position: absolute; top: -40px; right: -40px; width: 160px; height: 160px; background: rgba(6,182,212,0.08); border-radius: 50%;"></div>
          <div style="position: relative; z-index: 1;">
            <div style="font-size: 36px; margin-bottom: 8px;">🚀</div>
            <h3 style="font-size: 16px; font-weight: 900; text-transform: uppercase; margin: 0 0 4px; color: #06b6d4;">Rocket</h3>
            <p style="font-size: 10px; color: #6b7280; margin: 0 0 20px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em;">Тариф $110/год</p>

            <div class="cmp-card" style="border-color: rgba(168,85,247,0.2);">
              <div style="display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; margin-bottom: 4px;">
                <span>Доход с PRO (полные 5 ур.)</span>
                <span style="color: #22c55e;">50% + 5%</span>
              </div>
              <div id="syn-rocket-pro" style="font-size: 24px; font-weight: 900; color: #a855f7;">$0</div>
            </div>
            <div class="cmp-card" style="border-color: rgba(245,158,11,0.2); margin-top: 12px; margin-bottom: 16px;">
              <div style="display: flex; justify-content: space-between; font-size: 11px; color: #9ca3af; margin-bottom: 4px;">
                <span>Доход с Rocket (полные 10 ур.)</span>
                <span style="color: #22c55e;">40% + 3%</span>
              </div>
              <div id="syn-rocket-rocket" style="font-size: 24px; font-weight: 900; color: #f59e0b;">$0</div>
            </div>
            <div style="border-top: 1px solid rgba(6,182,212,0.2); padding-top: 16px; display: flex; justify-content: space-between; align-items: center;">
              <span style="font-size: 12px; font-weight: 700; color: #06b6d4; text-transform: uppercase;">Итого:</span>
              <span id="syn-rocket-total" style="font-size: 28px; font-weight: 900; color: #22c55e;">$0</span>
            </div>
          </div>
        </div>
      </div>

      <!-- BLOCK 4: LOST INCOME -->
      <div id="syn-loss-block" class="glass-panel hidden" style="border-radius: 32px; padding: 32px; margin-bottom: 24px; border: 1px solid rgba(239,68,68,0.3); background: linear-gradient(135deg, rgba(239,68,68,0.08), transparent);">
        <div style="display: flex; align-items: flex-start; gap: 16px; flex-wrap: wrap;">
          <div style="flex: 1; min-width: 200px;">
            <div style="display: inline-block; background: rgba(239,68,68,0.15); border: 1px solid rgba(239,68,68,0.3); color: #f87171; font-size: 10px; font-weight: 900; text-transform: uppercase; padding: 6px 16px; border-radius: 20px; margin-bottom: 12px;">⚠️ Упущенная выгода</div>
            <h2 style="font-size: 22px; font-weight: 900; margin: 0 0 8px; text-transform: uppercase;">Вы теряете <span id="syn-lost" style="color: #ef4444;">$0</span></h2>
            <p style="font-size: 12px; color: #9ca3af; line-height: 1.6; margin: 0;">Оставаясь на бесплатном тарифе Plane, вы экономите $110 в год, но дарите системе <strong id="syn-lost-num" style="color: #ef4444; font-weight: 900;">$0</strong>, которые генерируют ваши люди на 4–10 уровнях.</p>
          </div>
          <div style="shrink: 0; text-align: center;">
            <div style="font-size: 56px; line-height: 1;">📉</div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <a href="https://t.me/sethubble_biz_bot?start=calculator_rocket" target="_blank" class="btn-main" style="background: linear-gradient(135deg, #f59e0b, #ef4444); padding: 18px; border-radius: 20px; font-size: 14px; box-shadow: 0 0 40px rgba(239,68,68,0.2);">🔥 Купить SetHubble Rocket за $110 — открыть все уровни</a>

      <!-- TABLE -->
      <div class="glass-panel" style="border-radius: 32px; padding: 32px; margin-top: 24px; border-top: 1px solid rgba(255,255,255,0.06);">
        <h3 style="font-size: 12px; font-weight: 900; text-transform: uppercase; letter-spacing: 0.1em; color: #9ca3af; margin: 0 0 16px;">📋 Детализация по уровням</h3>
        <div style="overflow-x: auto;">
          <table id="syn-table" style="width: 100%; border-collapse: collapse; font-size: 12px; min-width: 600px;">
            <thead>
              <tr style="border-bottom: 1px solid rgba(255,255,255,0.1);">
                <th style="padding: 10px 8px; text-align: left; color: #6b7280; font-weight: 900; text-transform: uppercase; font-size: 10px;">Уровень</th>
                <th style="padding: 10px 8px; text-align: left; color: #6b7280; font-weight: 900; text-transform: uppercase; font-size: 10px;">Людей</th>
                <th style="padding: 10px 8px; text-align: left; color: #6b7280; font-weight: 900; text-transform: uppercase; font-size: 10px;">Купят PRO</th>
                <th style="padding: 10px 8px; text-align: left; color: #6b7280; font-weight: 900; text-transform: uppercase; font-size: 10px;">Купят Rocket</th>
                <th style="padding: 10px 8px; text-align: left; color: #6b7280; font-weight: 900; text-transform: uppercase; font-size: 10px;">Plane</th>
                <th style="padding: 10px 8px; text-align: left; color: #6b7280; font-weight: 900; text-transform: uppercase; font-size: 10px;">Rocket</th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>
    </div>

    <script src="/js/synergy-calculator.js"></script>
  </body>
</html>
