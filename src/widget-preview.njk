<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1">
<title>Widget Preview</title>
<meta name="robots" content="noindex, nofollow">
<style>
*{margin:0;padding:0;box-sizing:border-box}
body{min-height:100vh;background:#f8fafc;display:flex;align-items:flex-start;justify-content:center;padding-top:12px;font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif}
.label{font-size:11px;color:#94a3b8;background:#fff;padding:4px 12px;border-radius:20px;box-shadow:0 1px 3px rgba(0,0,0,.08)}
</style>
</head>
<body>
<span class="label">🎨 Предпросмотр виджета</span>
<script src="https://neuro-gen.ru/js/widget.js" data-bot="demo"></script>
<script>
(function(){
  function darken(hex,p){
    var r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
    r=Math.max(0,Math.min(255,Math.round(r*(1-p/100))));
    g=Math.max(0,Math.min(255,Math.round(g*(1-p/100))));
    b=Math.max(0,Math.min(255,Math.round(b*(1-p/100))));
    return '#'+[r,g,b].map(function(x){return x.toString(16).padStart(2,'0')}).join('');
  }
  function escCSS(s){return s.replace(/"/g,'\\"').replace(/</g,'\\3C ').replace(/>/g,'\\3E ')}

  function buildCSS(c){
    var r=[];
    if(c.accent){
      var g='linear-gradient(135deg,'+c.accent+','+darken(c.accent,30)+')';
      r.push('.neurogen-btn,.neurogen-ava,.neurogen-msg.user,#n-send{background:'+g+'!important}');
      r.push('.neurogen-btn{box-shadow:0 4px 20px '+c.accent+'66!important}');
      r.push('#n-input:focus{border-color:'+c.accent+'!important;box-shadow:0 0 0 3px '+c.accent+'4d!important}');
    }
    if(c.theme==='light'){
      r.push('.neurogen-popup{background:#fff!important}');
      r.push('.neurogen-hdr,.neurogen-foot{background:rgba(255,255,255,.98)!important}');
      r.push('.neurogen-hdr-t{color:#1e293b!important}');
      r.push('.neurogen-hdr-s{color:#64748b!important}');
      r.push('.neurogen-msg.bot{background:#f1f5f9!important;color:#1e293b!important}');
      r.push('.neurogen-close{color:#64748b!important}');
      r.push('#n-input{background:#f1f5f9!important;border-color:#e2e8f0!important;color:#1e293b!important}');
      if(!c.accent) r.push('.neurogen-msg.user,.neurogen-ava,.neurogen-btn,#n-send{background:linear-gradient(135deg,#3b82f6,#8b5cf6)!important}');
    }
    if(c.position==='left'){
      r.push('.neurogen-btn{right:auto!important;left:25px!important}');
      r.push('.neurogen-popup{right:auto!important;left:25px!important}');
    }
    if(c.title){
      r.push('.neurogen-hdr-t{font-size:0!important}');
      r.push('.neurogen-hdr-t::after{content:"'+escCSS(c.title)+'"!important;font-size:14px!important;font-weight:700!important;color:'+(c.theme==='light'?'#1e293b':'#e2e8f0')+'!important}');
    }
    if(c.avatar){
      r.push('.neurogen-ava{background:transparent!important;background-image:url('+c.avatar+')!important;background-size:cover!important;background-position:center!important}');
    }
    if(c.mobileFullscreen){
      r.push('@media(max-width:520px){.neurogen-popup{width:100vw!important;max-width:100vw!important;height:100vh!important;right:0!important;bottom:0!important;border-radius:0!important;max-height:100vh!important}}');
    }
    if(c.hideBadge){
      r.push('.neurogen-badge{display:none!important}');
    }
    return r.join('\n');
  }

  window.addEventListener('message',function(e){
    if(!e.data||e.data.type!=='widget-config')return;
    var css=buildCSS(e.data.config||{});
    var s=document.getElementById('ws');
    if(!s){s=document.createElement('style');s.id='ws';document.head.appendChild(s)}
    s.textContent=css;
    setTimeout(function(){
      if(window.neurogenWidget)window.neurogenWidget.open();
    },600);
  });
})();
</script>
</body>
</html>
