---
title: "Вход по PIN — NeuroGen"
permalink: /pin-login/
eleventyExcludeFromCollections: true
---
<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }}</title>
  <meta name="description" content="Войдите в приложение NeuroGen по ПИН-коду">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #0a0a1a;
      font-family: system-ui, -apple-system, sans-serif;
      color: #fff;
      padding: 20px;
    }
    .card {
      background: rgba(255,255,255,0.04);
      border: 1px solid rgba(255,255,255,0.08);
      border-radius: 24px;
      padding: 48px 40px;
      max-width: 420px;
      width: 100%;
      text-align: center;
    }
    .logo {
      width: 64px; height: 64px;
      background: linear-gradient(135deg, #6366f1, #a855f7);
      border-radius: 18px;
      display: flex; align-items: center; justify-content: center;
      margin: 0 auto 24px;
      font-size: 28px;
    }
    h1 { font-size: 22px; font-weight: 700; margin-bottom: 8px; }
    .subtitle { color: rgba(255,255,255,0.5); font-size: 14px; margin-bottom: 32px; }
    .field { margin-bottom: 16px; text-align: left; }
    .field label { display: block; font-size: 12px; font-weight: 600; color: rgba(255,255,255,0.5); margin-bottom: 6px; text-transform: uppercase; letter-spacing: 0.5px; }
    .field input {
      width: 100%; padding: 14px 16px;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 12px;
      color: #fff; font-size: 16px;
      outline: none; transition: border 0.2s;
    }
    .field input:focus { border-color: #6366f1; }
    .field input::placeholder { color: rgba(255,255,255,0.2); }
    .pin-input { font-size: 28px !important; letter-spacing: 8px; text-align: center; font-weight: 700; }
    .btn {
      width: 100%; padding: 16px;
      border: none; border-radius: 12px;
      font-size: 15px; font-weight: 700; cursor: pointer;
      background: linear-gradient(135deg, #6366f1, #a855f7);
      color: #fff; transition: opacity 0.2s;
    }
    .btn:hover { opacity: 0.9; }
    .btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .error-box {
      margin-top: 16px; padding: 12px 16px;
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.2);
      border-radius: 12px;
      color: #f87171; font-size: 13px;
    }
    .locked-box {
      margin-top: 16px; padding: 16px;
      background: rgba(234,179,8,0.08);
      border: 1px solid rgba(234,179,8,0.15);
      border-radius: 12px;
    }
    .locked-box .icon { font-size: 32px; margin-bottom: 8px; }
    .locked-box .msg { color: #fbbf24; font-size: 14px; font-weight: 600; }
    .locked-box .timer { color: rgba(255,255,255,0.5); font-size: 13px; margin-top: 4px; }
    .success-box {
      margin-top: 16px; padding: 16px;
      background: rgba(34,197,94,0.08);
      border: 1px solid rgba(34,197,94,0.15);
      border-radius: 12px;
    }
    .success-box .icon { font-size: 36px; margin-bottom: 8px; }
    .success-box .msg { color: #22c55e; font-size: 14px; font-weight: 600; }
    .token-display {
      margin-top: 12px;
      background: rgba(0,0,0,0.3); border-radius: 8px;
      padding: 8px 12px;
      font-size: 10px; color: rgba(255,255,255,0.4);
      word-break: break-all; font-family: monospace;
      cursor: pointer; user-select: all;
    }
    .token-display:hover { color: rgba(255,255,255,0.7); }
    .hidden { display: none; }
    .spinner {
      display: inline-block; width: 18px; height: 18px;
      border: 2px solid rgba(255,255,255,0.2);
      border-top-color: #fff; border-radius: 50%;
      animation: spin 0.6s linear infinite;
      vertical-align: middle; margin-right: 8px;
    }
    @keyframes spin { to { transform: rotate(360deg); } }
    .footer { margin-top: 24px; font-size: 11px; color: rgba(255,255,255,0.2); }
    .help { font-size: 12px; color: rgba(255,255,255,0.3); margin-top: 16px; }
    .help a { color: #6366f1; text-decoration: none; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">🧠</div>
    <h1>Вход по ПИН-коду</h1>
    <p class="subtitle">Используйте ПИН из вашего профиля NeuroGen</p>

    <form id="pinForm">
      <div class="field">
        <label for="userId">Telegram ID или UUID</label>
        <input id="userId" type="text" placeholder="123456789" autocomplete="off" required>
      </div>
      <div class="field">
        <label for="pin">ПИН-код</label>
        <input id="pin" class="pin-input" type="password" inputmode="numeric" maxlength="4" placeholder="••••" autocomplete="off" required>
      </div>
      <button id="submitBtn" class="btn" type="submit">Войти</button>
    </form>

    <div id="errorBox" class="error-box hidden"></div>

    <div id="lockedBox" class="locked-box hidden">
      <div class="icon">🔒</div>
      <div class="msg">PIN временно заблокирован</div>
      <div class="timer" id="lockTimer"></div>
    </div>

    <div id="successBox" class="success-box hidden">
      <div class="icon">✅</div>
      <div class="msg">Вход выполнен успешно</div>
      <div id="tokenDisplay" class="token-display hidden"></div>
      <button id="copyBtn" class="btn" style="margin-top:12px;padding:10px;font-size:13px">Копировать токен</button>
    </div>

    <div class="help">
      Не знаете ПИН? <a href="https://t.me/sethubble_biz_bot" target="_blank">Запросите в боте</a>
    </div>
    <div class="footer">NeuroGen Platform &copy; 2026</div>
  </div>

  <script>
    const params = new URLSearchParams(window.location.search);
    const API_BASE = params.get("api") || "https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net";
    const REDIRECT_URL = params.get("redirect");

    const form = document.getElementById("pinForm");
    const userIdInput = document.getElementById("userId");
    const pinInput = document.getElementById("pin");
    const submitBtn = document.getElementById("submitBtn");
    const errorBox = document.getElementById("errorBox");
    const lockedBox = document.getElementById("lockedBox");
    const lockTimer = document.getElementById("lockTimer");
    const successBox = document.getElementById("successBox");
    const tokenDisplay = document.getElementById("tokenDisplay");
    const copyBtn = document.getElementById("copyBtn");

    let lockCountdown = null;

    function showError(msg) {
      errorBox.textContent = msg;
      errorBox.classList.remove("hidden");
      lockedBox.classList.add("hidden");
      successBox.classList.add("hidden");
    }

    function showLocked(remainingMin) {
      errorBox.classList.add("hidden");
      successBox.classList.add("hidden");
      lockedBox.classList.remove("hidden");
      const endMs = Date.now() + remainingMin * 60 * 1000;
      function tick() {
        const left = Math.max(0, Math.ceil((endMs - Date.now()) / 1000));
        if (left <= 0) {
          lockTimer.textContent = "Блокировка снята. Попробуйте снова.";
          lockedBox.classList.add("hidden");
          clearInterval(lockCountdown);
          return;
        }
        const m = Math.floor(left / 60);
        const s = left % 60;
        lockTimer.textContent = `Повторите через ${m}:${String(s).padStart(2, "0")}`;
      }
      tick();
      lockCountdown = setInterval(tick, 1000);
    }

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const userId = userIdInput.value.trim();
      const pin = pinInput.value.trim();

      if (!userId || pin.length !== 4) {
        showError("Введите ID пользователя и 4-значный ПИН-код");
        return;
      }

      errorBox.classList.add("hidden");
      lockedBox.classList.add("hidden");
      successBox.classList.add("hidden");
      if (lockCountdown) { clearInterval(lockCountdown); lockCountdown = null; }

      submitBtn.disabled = true;
      submitBtn.innerHTML = '<span class="spinner"></span> Проверка...';

      try {
        const res = await fetch(`${API_BASE}/?action=validate-pin`, {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ userId, pin }),
        });

        const data = await res.json();

        if (res.status === 200 && data.success) {
          localStorage.setItem("neurogen_jwt", data.token);
          successBox.classList.remove("hidden");
          tokenDisplay.textContent = data.token;
          tokenDisplay.classList.remove("hidden");
          copyBtn.classList.remove("hidden");
          form.classList.add("hidden");

          if (REDIRECT_URL) {
            setTimeout(() => {
              window.location.href = REDIRECT_URL.includes("?")
                ? `${REDIRECT_URL}&token=${data.token}`
                : `${REDIRECT_URL}?token=${data.token}`;
            }, 1500);
          }
        } else if (res.status === 423) {
          showLocked(data.remainingMin || 15);
        } else if (res.status === 401) {
          const left = data.attemptsLeft !== undefined ? data.attemptsLeft : "?";
          showError(`Неверный ПИН. Осталось попыток: ${left}`);
          pinInput.value = "";
          pinInput.focus();
        } else {
          showError(data.error || "Ошибка сервера");
        }
      } catch (err) {
        showError("Ошибка сети. Проверьте подключение.");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Войти";
      }
    });

    copyBtn.addEventListener("click", () => {
      navigator.clipboard.writeText(tokenDisplay.textContent);
      copyBtn.textContent = "✅ Скопировано";
      setTimeout(() => { copyBtn.textContent = "Копировать токен"; }, 2000);
    });

    pinInput.addEventListener("input", () => {
      if (pinInput.value.length > 4) pinInput.value = pinInput.value.slice(0, 4);
    });
  </script>
</body>
</html>
