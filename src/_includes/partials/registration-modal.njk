<!-- ============================================== -->
<!-- МОДАЛЬНОЕ ОКНО: Email + Выбор Платформы        -->
<!-- ============================================== -->
<div id="leadModal" class="hidden fixed inset-0 z-[100] flex items-center justify-center px-4 bg-black/80 backdrop-blur-sm transition-opacity duration-300 opacity-0">
  <div id="modalContent" class="modal-enter w-full max-w-md bg-[#0a0a0a] border border-white/10 rounded-3xl p-6 relative shadow-2xl">
    <button id="closeModal" class="absolute top-4 right-4 text-gray-500 hover:text-white transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
    </button>

    <!-- ШАГ 1: Сбор Email -->
    <div id="stepEmail" class="block">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-cyan-500 to-purple-600 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-purple-500/20">📧</div>
        <h3 class="text-2xl font-bold text-white mb-2">Куда отправить доступы?</h3>
        <p class="text-sm text-gray-400">Мы пришлем резервную ссылку на твою систему и материалы.</p>
      </div>
      <form id="emailForm" class="space-y-4">
        <div>
          <input type="text" id="userName" required placeholder="Ваше имя (или псевдоним)" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 transition-all text-center text-lg mb-3">
          <input type="email" id="userEmail" required placeholder="твой@email.com" class="w-full bg-white/5 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-gray-500 focus:outline-none focus:border-purple-500 focus:ring-1 focus:ring-purple-500 transition-all text-center text-lg">
        </div>

        <div class="bg-purple-900/20 border border-purple-500/30 p-3 rounded-lg text-[11px] text-gray-400 text-left leading-tight">
          ⚠️ <b>Внимание:</b> Укажите корректное имя. Именно оно будет отображаться на <b>вашем личном сайте</b> для приглашенных вами партнеров.
        </div>

        <button type="submit" id="submitEmailBtn" class="w-full bg-gradient-to-r from-cyan-500 to-purple-500 text-white font-bold py-3.5 rounded-xl hover:opacity-90 transition-opacity flex justify-center items-center gap-2">
          ПРОДОЛЖИТЬ
        </button>
        <p id="emailError" class="text-red-400 text-xs text-center hidden">Пожалуйста, проверьте данные</p>
      </form>
      <p class="text-[10px] text-gray-500 text-center mt-4">Нажимая кнопку, ты соглашаешься с политикой конфиденциальности.</p>
    </div>

    <!-- ШАГ 1.5: Приветствие для вернувшегося пользователя -->
    <div id="stepWelcome" class="hidden">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-cyan-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-green-500/20">👋</div>
        <h3 class="text-2xl font-bold text-white mb-2">С возвращением, <span id="welcomeName" class="text-cyan-400">друг</span>!</h3>
        <p class="text-sm text-gray-400">Твой аккаунт уже активен. Выбери канал, чтобы продолжить:</p>
      </div>
      <div class="space-y-3">
        <button id="btnTelegram" class="w-full relative group overflow-hidden bg-[#2AABEE]/10 border border-[#2AABEE]/30 hover:border-[#2AABEE] rounded-xl p-4 text-left transition-all flex items-center gap-4">
          <div class="text-3xl">✈️</div>
          <div><div class="font-bold text-white group-hover:text-[#2AABEE] transition-colors">Через Telegram-бота</div><div class="text-xs text-gray-400">Быстро, удобно, всё в мессенджере</div></div>
        </button>
        <button id="btnVK" class="w-full relative group overflow-hidden bg-[#0077FF]/10 border border-[#0077FF]/30 hover:border-[#0077FF] rounded-xl p-4 text-left transition-all flex items-center gap-4">
          <div class="text-3xl">💬</div>
          <div><div class="font-bold text-white group-hover:text-[#0077FF] transition-colors">Через ВКонтакте</div><div class="text-xs text-gray-400">Не заблокирован, аудитория 80M+ в РФ</div></div>
        </button>
        <button id="btnWeb" class="w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-cyan-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4">
          <div class="text-3xl">🌐</div>
          <div><div class="font-bold text-white group-hover:text-cyan-400 transition-colors">Через Web-сайт</div><div class="text-xs text-gray-400">Работает в любом браузере, без VPN</div></div>
        </button>
      </div>
    </div>

    <!-- ШАГ 2: Выбор платформы (используется для urlStep=channels) -->
    <div id="stepChoice" class="hidden">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-blue-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-blue-500/20">✅</div>
        <h3 class="text-2xl font-bold text-white mb-2">Отлично!</h3>
        <p class="text-sm text-gray-400">Где тебе удобнее развернуть систему?</p>
      </div>
      <div class="space-y-3">
        <button id="btnChoiceTelegram" class="btn-channel w-full relative group overflow-hidden bg-[#2AABEE]/10 border border-[#2AABEE]/30 hover:border-[#2AABEE] rounded-xl p-4 text-left transition-all flex items-center gap-4" data-channel="telegram">
          <div class="text-3xl">✈️</div>
          <div><div class="font-bold text-white group-hover:text-[#2AABEE] transition-colors">Через Telegram-бота</div><div class="text-xs text-gray-400">Быстро, удобно, всё в мессенджере</div></div>
        </button>
        <button id="btnChoiceVK" class="btn-channel w-full relative group overflow-hidden bg-[#0077FF]/10 border border-[#0077FF]/30 hover:border-[#0077FF] rounded-xl p-4 text-left transition-all flex items-center gap-4" data-channel="vk">
          <div class="text-3xl">💬</div>
          <div><div class="font-bold text-white group-hover:text-[#0077FF] transition-colors">Через ВКонтакте</div><div class="text-xs text-gray-400">Не заблокирован, аудитория 80M+ в РФ</div></div>
        </button>
        <button id="btnChoiceWeb" class="btn-channel w-full relative group overflow-hidden bg-white/5 border border-white/10 hover:border-cyan-500/50 rounded-xl p-4 text-left transition-all flex items-center gap-4" data-channel="web">
          <div class="text-3xl">🌐</div>
          <div><div class="font-bold text-white group-hover:text-cyan-400 transition-colors">Через Web-сайт</div><div class="text-xs text-gray-400">Работает в любом браузере, без VPN</div></div>
        </button>
      </div>
    </div>

    <div id="email-submitted" class="hidden">
      <div class="text-center mb-6">
        <div class="w-16 h-16 bg-gradient-to-br from-green-400 to-emerald-500 rounded-full flex items-center justify-center text-2xl mx-auto mb-4 shadow-lg shadow-green-500/20">✉️</div>
        <h3 class="text-2xl font-bold text-white mb-2">Проверь свою почту!</h3>
        <p class="text-sm text-gray-400 mb-2">Мы отправили ссылку для подтверждения на:</p>
        <p class="text-lg font-bold text-green-400 mb-4" id="submitted-email-value"></p>
        <p class="text-xs text-gray-500">Перейди по ссылке в письме, чтобы подтвердить email и продолжить настройку.</p>
      </div>
      <div class="flex gap-3 mt-4">
        <button id="resendEmailBtn" class="flex-1 bg-white/10 border border-white/20 text-white font-bold py-2.5 rounded-xl hover:bg-white/20 transition-all text-sm">
          🔄 Отправить ещё раз
        </button>
        <button id="changeEmailBtn" class="flex-1 bg-white/10 border border-white/20 text-white font-bold py-2.5 rounded-xl hover:bg-white/20 transition-all text-sm">
          ✏️ Изменить email
        </button>
      </div>
      <p id="resendStatus" class="hidden text-center text-xs text-gray-400 mt-2"></p>
      <div class="mt-6 border-t border-white/10 pt-6">
        <p class="text-sm text-gray-400 mb-3 text-center">Или введи код из письма:</p>
        <div class="flex gap-2">
          <input type="text" id="verificationCode" maxlength="8" placeholder="XXXXXXXX"
            class="flex-1 bg-white/5 border border-white/20 text-white text-center text-lg font-mono tracking-widest rounded-xl py-2.5 focus:outline-none focus:border-indigo-500 uppercase">
          <button id="verifyCodeBtn" class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-bold py-2.5 px-6 rounded-xl hover:opacity-90 transition-all text-sm">
            Подтвердить
          </button>
        </div>
        <p id="verifyCodeStatus" class="hidden text-center text-xs mt-2"></p>
      </div>
    </div>
  </div>
</div>