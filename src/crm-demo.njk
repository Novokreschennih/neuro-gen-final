---
title: "NeuroGen CRM | Интерактивное Демо"
permalink: /crm/demo/
eleventyExcludeFromCollections: true
---
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>{{ title }}</title>
    <!-- Асинхронная загрузка, чтобы не тормозить страницу -->
    <script src="https://telegram.org/js/telegram-web-app.js" async></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
      body { background-color: #0f172a; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; }
      .stat-card { background: rgba(30, 41, 59, 0.5); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(10px); }
      .stat-card.paid { border-color: rgba(34, 197, 94, 0.4); background: rgba(34, 197, 94, 0.05); }
      .lead-card { transition: all 0.2s; cursor: pointer; }
      .lead-card:active { transform: scale(0.98); background: rgba(255,255,255,0.05); }
      ::-webkit-scrollbar { width: 0px; height: 0px; }
      .no-scrollbar::-webkit-scrollbar { display: none; }
      
      /* Active states for filters */
      .filter-btn { background: #1e293b; color: #94a3b8; }
      .filter-btn.active { background: #4f46e5; color: #ffffff; }
      .ch-btn { color: #64748b; }
      .ch-btn.active { color: #818cf8; }
    </style>
  </head>
  <body class="text-slate-200 min-h-screen pb-32">
    <!-- Тонкий банер Демо -->
    <div class="bg-indigo-600 text-white text-[10px] font-black py-1.5 text-center uppercase tracking-widest sticky top-0 z-50 shadow-lg">
      Демо-режим: Опробуйте мощь NeuroGen CRM
    </div>

    <div class="max-w-2xl mx-auto px-4 pt-6">
      <!-- Header -->
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-2xl font-black tracking-tight">МОИ <span class="text-indigo-400">КЛИЕНТЫ</span></h1>
          <p class="text-xs text-slate-400">Визуализация вашей бизнес-сети</p>
        </div>
        <div class="w-10 h-10 rounded-full bg-slate-800 border border-slate-700 flex items-center justify-center text-sm font-bold shadow-inner">Д</div>
      </div>

      <!-- Stats -->
      <div class="grid grid-cols-2 gap-4 mb-6">
        <div class="stat-card rounded-3xl p-5 shadow-xl cursor-pointer" onclick="showProAlert('Аналитика базы')">
          <div class="text-3xl font-black mb-1">124</div>
          <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Всего лидов</div>
        </div>
        <div class="stat-card paid rounded-3xl p-5 shadow-xl cursor-pointer" onclick="showProAlert('Финансы и продажи')">
          <div class="text-3xl font-black text-green-400 mb-1">15</div>
          <div class="text-[10px] text-green-500/70 uppercase font-bold tracking-wider">Продажи PRO</div>
        </div>
      </div>

      <!-- Stage Funnel -->
      <div class="bg-slate-900/50 border border-slate-800 rounded-3xl p-4 mb-8 overflow-x-auto no-scrollbar cursor-pointer" onclick="showProAlert('Конверсии воронки')">
        <div class="flex gap-6 min-w-max text-center">
            <div class="px-2"><div class="text-[10px] text-slate-500 uppercase font-bold mb-1">Старт</div><div class="font-black text-lg">45</div></div>
            <div class="w-px h-8 bg-slate-800 self-center"></div>
            <div class="px-2"><div class="text-[10px] text-slate-500 uppercase font-bold mb-1">Обучение</div><div class="font-black text-lg">40</div></div>
            <div class="w-px h-8 bg-slate-800 self-center"></div>
            <div class="px-2"><div class="text-[10px] text-slate-500 uppercase font-bold mb-1">Оффер</div><div class="font-black text-lg text-orange-400">24</div></div>
            <div class="w-px h-8 bg-slate-800 self-center"></div>
            <div class="px-2"><div class="text-[10px] text-green-500/70 uppercase font-bold mb-1">Выдача</div><div class="font-black text-lg text-green-400">15</div></div>
        </div>
      </div>

      <!-- Filters & Search -->
      <div class="sticky top-[26px] z-40 bg-[#0f172a]/95 backdrop-blur-xl py-4 -mx-4 px-4 space-y-4 shadow-[0_10px_30px_-10px_rgba(15,23,42,1)]">
          <div class="relative">
              <input type="text" id="demoSearch" placeholder="Поиск по имени или ID..." class="w-full bg-slate-800 border border-slate-700 rounded-2xl py-3.5 pl-11 pr-4 text-sm text-white placeholder-slate-500 outline-none focus:border-indigo-500 transition-all shadow-inner">
              <span class="absolute left-4 top-3.5 text-slate-500">🔍</span>
          </div>
          
          <div class="flex gap-2 overflow-x-auto no-scrollbar" id="funnelFilters">
              <button data-target="all" class="filter-btn active px-4 py-2 rounded-xl text-[10px] font-black uppercase whitespace-nowrap transition-colors">Все</button>
              <button data-target="PRO" class="filter-btn px-4 py-2 rounded-xl text-[10px] font-black uppercase whitespace-nowrap transition-colors">✅ PRO</button>
              <button data-target="Delivery" class="filter-btn px-4 py-2 rounded-xl text-[10px] font-black uppercase whitespace-nowrap transition-colors">🎁 Выдача</button>
              <button data-target="Tripwire" class="filter-btn px-4 py-2 rounded-xl text-[10px] font-black uppercase whitespace-nowrap transition-colors">⌛ Думают</button>
          </div>

          <div class="flex gap-4 overflow-x-auto no-scrollbar border-t border-slate-800/50 pt-3" id="channelFilters">
              <button data-target="all" class="ch-btn active text-[10px] font-black uppercase transition-colors whitespace-nowrap">🌐 Все каналы</button>
              <button data-target="tg" class="ch-btn text-[10px] font-black uppercase transition-colors whitespace-nowrap">✈️ TG</button>
              <button data-target="vk" class="ch-btn text-[10px] font-black uppercase transition-colors whitespace-nowrap">💬 VK</button>
              <button data-target="web" class="ch-btn text-[10px] font-black uppercase transition-colors whitespace-nowrap">💻 Web</button>
          </div>
      </div>

      <!-- Lead List -->
      <div id="demoLeadsList" class="space-y-3 mt-6">
          <!-- Генерируется через JS -->
      </div>
    </div>

    <!-- Actions Panel -->
    <div class="fixed bottom-0 left-0 right-0 p-6 bg-[#0f172a]/90 backdrop-blur-xl border-t border-slate-800 z-50">
        <div class="max-w-2xl mx-auto flex gap-3">
            <button onclick="showProAlert('Массовая рассылка')" class="flex-1 bg-gradient-to-r from-indigo-600 to-purple-600 hover:from-indigo-500 hover:to-purple-500 text-white font-black py-4 rounded-2xl text-xs uppercase shadow-xl shadow-indigo-500/20 active:scale-95 transition-all flex items-center justify-center gap-2">
                <span>📢</span> Запустить рассылку
            </button>
            <button onclick="showProAlert('Экспорт CSV')" class="bg-slate-800 hover:bg-slate-700 text-white p-4 rounded-2xl border border-slate-700 transition-colors flex items-center justify-center">
                📥
            </button>
        </div>
    </div>

    <script>
      // Функция вызова алерта (работает и в браузере, и в Telegram)
      function showProAlert(feature) {
          const tg = window.Telegram?.WebApp;
          if (tg?.HapticFeedback) tg.HapticFeedback.notificationOccurred("warning");
          
          const msg = `Функция «${feature}» доступна только на тарифе PRO 🔒\n\nВ демо-режиме вы видите примеры лидов. Активируйте PRO-статус, чтобы управлять своей реальной базой и запускать по ним рассылки!`;
          
          if (tg?.isVersionAtLeast && tg.isVersionAtLeast("6.2")) {
              tg.showPopup({ 
                  title: "Требуется PRO-статус", 
                  message: msg, 
                  buttons: [
                      { type: "default", text: "Активировать PRO", id: "buy" }, 
                      { type: "cancel", text: "Закрыть" }
                  ] 
              }, (id) => {
                  if(id === "buy") window.open("https://neuro-gen.ru/", "_blank");
              });
          } else {
              alert(msg);
          }
      }

      // ГЕНЕРАЦИЯ ФЕЙКОВЫХ ДАННЫХ
      const names = ["Алексей В.", "Елена", "Марина Топ", "Дмитрий_Crypto", "Ivan_IT", "Кристина B2B", "Николай", "SMM_Master", "Ольга П.", "Артем", "Виктория 🚀", "Сергей Бизнес", "Анна Т.", "Максим"];
      const stages = ["START", "Training", "Tripwire", "Delivery"];
      const channels = ["tg", "vk", "web", "email"];

      // Генерируем 124 лида
      const mockLeads = Array.from({length: 124}, (_, i) => {
          const stage = stages[Math.floor(Math.random() * stages.length)];
          const isPro = stage === "Delivery" || Math.random() > 0.9;
          
          return {
              id: 100000 + Math.floor(Math.random() * 900000),
              name: names[Math.floor(Math.random() * names.length)],
              stage: stage,
              channel: channels[Math.floor(Math.random() * channels.length)],
              isPro: isPro,
              time: Math.floor(Math.random() * 60) + " мин. назад"
          };
      });

      // Стейт фильтров
      let currentStage = 'all';
      let currentChannel = 'all';

      // Рендер карточек
      function renderLeads(leads) {
          const list = document.getElementById("demoLeadsList");
          
          if (leads.length === 0) {
              list.innerHTML = `<div class="text-center py-12 text-slate-500"><div class="text-4xl mb-3">📭</div><p class="text-sm">Никого не найдено</p></div>`;
              return;
          }

          const stageLabels = {
              "START": "Старт",
              "Training": "Обучение",
              "Tripwire": "Оффер",
              "Delivery": "Выдача"
          };

          list.innerHTML = leads.map(l => {
              const bgClass = l.isPro ? "bg-indigo-900/20 border-indigo-500/30" : "bg-slate-800/40 border-slate-700/50";
              const progressWidth = l.stage === "START" ? "10%" : l.stage === "Training" ? "40%" : l.stage === "Tripwire" ? "75%" : "100%";
              
              return `
                <div class="lead-card ${bgClass} border p-4 rounded-3xl flex items-center justify-between" onclick="showProAlert('Детальная карточка лида')">
                    <div class="flex items-center gap-4">
                        <div class="w-10 h-10 rounded-2xl bg-slate-800 border border-slate-700 flex items-center justify-center text-[10px] font-black text-slate-400">
                            ${l.channel.toUpperCase()}
                        </div>
                        <div>
                            <div class="text-sm font-bold flex items-center gap-2 text-white">
                                ${l.name}
                                ${l.isPro ? '<span class="text-[8px] bg-indigo-500 text-white px-1.5 py-0.5 rounded-md uppercase tracking-wider">PRO</span>' : ''}
                            </div>
                            <div class="text-[10px] text-slate-500 mt-0.5">ID: ${l.id} • ${l.time}</div>
                        </div>
                    </div>
                    <div class="text-right w-16">
                        <div class="text-[9px] font-black uppercase text-slate-500 mb-1.5">${stageLabels[l.stage]}</div>
                        <div class="w-full h-1 bg-slate-800 rounded-full overflow-hidden">
                            <div class="${l.isPro ? 'bg-green-400' : 'bg-indigo-500'} h-full rounded-full" style="width: ${progressWidth}"></div>
                        </div>
                    </div>
                </div>
              `;
          }).join('');
      }

      // Главная функция фильтрации
      function runDemoFilter() {
          const query = document.getElementById("demoSearch").value.toLowerCase();
          
          const filtered = mockLeads.filter(l => {
              const matchSearch = l.name.toLowerCase().includes(query) || l.id.toString().includes(query);
              
              let matchStage = true;
              if (currentStage === 'PRO') matchStage = l.isPro;
              else if (currentStage !== 'all') matchStage = l.stage === currentStage;
              
              const matchChannel = currentChannel === 'all' || l.channel === currentChannel;
              
              return matchSearch && matchStage && matchChannel;
          });
          
          renderLeads(filtered);
      }

      // Обработка кликов по фильтрам воронки
      document.getElementById('funnelFilters').addEventListener('click', (e) => {
          if (e.target.tagName === 'BUTTON') {
              document.querySelectorAll('#funnelFilters button').forEach(b => b.classList.remove('active'));
              e.target.classList.add('active');
              currentStage = e.target.dataset.target;
              runDemoFilter();
          }
      });

      // Обработка кликов по фильтрам каналов
      document.getElementById('channelFilters').addEventListener('click', (e) => {
          if (e.target.tagName === 'BUTTON') {
              document.querySelectorAll('#channelFilters button').forEach(b => b.classList.remove('active'));
              e.target.classList.add('active');
              currentChannel = e.target.dataset.target;
              runDemoFilter();
          }
      });

      // Поиск
      document.getElementById('demoSearch').addEventListener('input', runDemoFilter);

      // Инициализация при старте
      window.addEventListener('DOMContentLoaded', () => {
          try {
              const tg = window.Telegram?.WebApp;
              if (tg) {
                  tg.expand();
                  tg.ready();
              }
          } catch(e) {}
          
          renderLeads(mockLeads);
      });
    </script>
  </body>
</html>
