    <script>
    (function() {
      document.getElementById("body-container").classList.add("show-universal");
      const Storage = {
        set: (key, val) => { try { localStorage.setItem(key, val); } catch(e) {} }
      };
      const params = new URLSearchParams(window.location.search);
      const afid = params.get("afid");
      if (afid && /^\d{1,10}$/.test(afid)) {
        Storage.set("neurogen_partner_afid", afid);
      }
      const page = params.get("page");
      if (page) {
        try {
          let partnerId;
          if (/^[0-9a-fA-F]+$/.test(page) && page.length % 2 === 0) {
            let decoded = "";
            for (let i = 0; i < page.length; i += 2) {
              decoded += String.fromCharCode(parseInt(page.substr(i, 2), 16));
            }
            if (decoded.length > 1) partnerId = decoded.trim();
          } else {
            partnerId = page.trim();
          }
          if (partnerId) {
            Storage.set("neurogen_partner_id", partnerId);
            var refBtn = document.getElementById("btn-partner-ref");
            if (refBtn) refBtn.href = "https://sethubble.com/ru/" + encodeURIComponent(partnerId);
            var refBtnCta = document.getElementById("btn-partner-ref-cta");
            if (refBtnCta) refBtnCta.href = "https://sethubble.com/ru/" + encodeURIComponent(partnerId);
          }
        } catch(e) {}
      }
    })();
    </script>
