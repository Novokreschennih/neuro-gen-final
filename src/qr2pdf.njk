<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR в Презентацию | NeuroGen Promo-Kit</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://unpkg.com/pdf-lib@1.17.1/dist/pdf-lib.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/qrcode/build/qrcode.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700;900&display=swap" rel="stylesheet">
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #0f172a; }
        .bg-glass { background: rgba(30, 41, 59, 0.7); backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.1); }
        input[type="range"] { -webkit-appearance: none; appearance: none; background: #1e293b; height: 6px; border-radius: 3px; }
        input[type="range"]::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 18px; height: 18px; background: #a855f7; border-radius: 50%; cursor: pointer; transition: all 0.2s; border: 2px solid #fff; }
        input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.1); box-shadow: 0 0 10px rgba(168, 85, 247, 0.5); }
        .animate-pulse-slow { animation: pulse 3s cubic-bezier(0.4, 0, 0.6, 1) infinite; }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: .7; } }
    </style>
</head>
<body class="text-slate-200">

    <div id="auth-screen" class="fixed inset-0 z-50 flex items-center justify-center bg-slate-900">
        <div class="text-center space-y-4">
            <div id="auth-loader" class="flex flex-col items-center">
                <div class="w-12 h-12 border-4 border-purple-500/30 border-t-purple-500 rounded-full animate-spin mb-4"></div>
                <h2 class="text-xl font-bold tracking-wider animate-pulse-slow">Проверка доступа...</h2>
                <p class="text-slate-400 text-sm mt-2">Проверка авторизации через Promo-Kit NeuroGen</p>
            </div>
            <div id="auth-error" class="hidden max-w-md w-full px-6">
                <div class="bg-slate-800 p-8 rounded-3xl border border-red-500/30 shadow-2xl space-y-6">
                    <div class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto ring-8 ring-red-500/5 text-red-500 text-4xl">🔒</div>
                    <div>
                        <h2 class="text-2xl font-bold text-white mb-2 leading-tight">Доступ ограничен</h2>
                        <p id="error-message" class="text-slate-400 text-sm">Приложение доступно только партнерам через платформу Promo-Kit NeuroGen.</p>
                    </div>
                    <div class="pt-2">
                        <a href="https://t.me/sethubble_biz_bot" target="_blank" class="block w-full py-3.5 bg-gradient-to-r from-purple-600 to-blue-600 hover:from-purple-500 hover:to-blue-500 text-white rounded-xl font-bold transition-all shadow-lg active:scale-95">Вернуться в NeuroGen</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="app-content" class="hidden min-h-screen p-4 sm:p-8 max-w-[1440px] mx-auto">
        <header class="flex flex-col sm:flex-row items-center justify-between gap-4 mb-8">
            <div>
                <h1 class="text-2xl sm:text-3xl font-black tracking-widest text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-cyan-400 uppercase">QR в Презентацию</h1>
                <p class="text-xs sm:text-sm text-slate-400">Добавляйте ваши QR-коды в PDF презентации за секунды.</p>
            </div>
            <div class="flex items-center gap-3 bg-glass p-2 pr-4 rounded-full">
                <div id="user-avatar" class="w-10 h-10 rounded-full bg-gradient-to-br from-purple-600 to-blue-600 flex items-center justify-center text-white font-bold">P</div>
                <div class="hidden sm:block">
                    <div id="user-name" class="text-sm font-bold leading-tight">Партнер</div>
                    <div class="text-[10px] text-slate-500 uppercase tracking-tighter">Verified Partner</div>
                </div>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">
            <div class="lg:col-span-5 space-y-6">
                <section class="bg-glass rounded-2xl overflow-hidden shadow-xl">
                    <div class="flex border-b border-slate-700">
                        <button onclick="setTab('pdf')" id="tab-pdf" class="flex-1 py-4 text-sm font-bold text-center transition-all bg-purple-500/10 text-purple-400 border-b-2 border-purple-500">Загрузить PDF</button>
                        <button onclick="setTab('text')" id="tab-text" class="flex-1 py-4 text-sm font-bold text-center transition-all text-slate-400 hover:text-slate-200">Текст презентации</button>
                    </div>
                    
                    <div class="p-6 space-y-6">
                        <div id="input-pdf">
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">PDF Файл</label>
                            <div onclick="document.getElementById('file-input').click()" class="border-2 border-dashed border-slate-600 hover:border-purple-500 rounded-xl p-8 text-center cursor-pointer transition-all bg-slate-800/30">
                                <input type="file" id="file-input" accept="application/pdf" class="hidden" onchange="handleFile(this)">
                                <div id="file-placeholder">
                                    <div class="text-4xl mb-2 grayscale opacity-50">📄</div>
                                    <p class="font-bold text-slate-300">Выберите PDF</p>
                                </div>
                                <div id="file-info" class="hidden">
                                    <div class="text-4xl mb-2">✅</div>
                                    <p id="file-name" class="font-bold text-purple-400 break-all"></p>
                                    <p id="file-size" class="text-xs text-purple-500/70"></p>
                                </div>
                            </div>
                        </div>

                        <div id="input-text" class="hidden space-y-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Заголовок</label>
                                <input type="text" id="text-title" placeholder="Заголовок презентации" oninput="update()" class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 focus:ring-2 focus:ring-purple-500 outline-none">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Текст</label>
                                <textarea id="text-content" placeholder="Ваш текст..." oninput="update()" class="w-full h-32 bg-slate-900 border border-slate-700 rounded-xl p-3 focus:ring-2 focus:ring-purple-500 outline-none resize-none"></textarea>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="bg-glass rounded-2xl p-6 shadow-xl space-y-6">
                    <h3 class="font-bold text-purple-400 flex items-center gap-2">⚙️ Параметры QR</h3>
                    <div class="space-y-4">
                        <div>
                            <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Ссылка (Link)</label>
                            <input type="text" id="qr-link" placeholder="https://..." oninput="update()" class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 focus:ring-2 focus:ring-purple-500 outline-none font-mono text-sm">
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Размер</label>
                                <input type="range" id="qr-size" min="50" max="250" value="120" oninput="update()" class="w-full">
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-slate-400 uppercase tracking-widest mb-2">Отступ</label>
                                <input type="range" id="qr-margin" min="10" max="100" value="30" oninput="update()" class="w-full">
                            </div>
                        </div>
                        <div>
                            <select id="qr-position" onchange="update()" class="w-full bg-slate-900 border border-slate-700 rounded-xl p-3 focus:ring-2 focus:ring-purple-500 outline-none">
                                <option value="bottom-right">Справа внизу</option>
                                <option value="bottom-left">Слева внизу</option>
                                <option value="top-right">Справа вверху</option>
                                <option value="top-left">Слева вверху</option>
                            </select>
                        </div>
                    </div>
                </section>
            </div>

            <div class="lg:col-span-7 sticky top-8">
                <div class="bg-glass rounded-2xl p-4 shadow-2xl space-y-4">
                    <div class="flex items-center justify-between px-2">
                        <div class="flex items-center gap-2">
                            <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
                            <h3 class="text-sm font-bold uppercase tracking-widest">Предпросмотр</h3>
                        </div>
                        <button onclick="handleDownload()" id="btn-download" class="hidden bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white px-6 py-2 rounded-full font-bold text-sm shadow-lg transition-all active:scale-95">Скачать PDF</button>
                    </div>
                    <div id="preview-container" class="aspect-[4/3] bg-slate-900 rounded-xl overflow-hidden relative border border-slate-700/50">
                        <div id="preview-empty" class="absolute inset-0 flex flex-col items-center justify-center p-8 text-center">
                            <div class="text-6xl mb-4 grayscale opacity-20">🖨️</div>
                            <p class="text-slate-500 text-sm">Загрузите или введите текст</p>
                        </div>
                        <div id="preview-loading" class="hidden absolute inset-0 bg-slate-900/60 backdrop-blur-sm flex items-center justify-center z-10"><div class="w-10 h-10 border-4 border-purple-500/20 border-t-purple-500 rounded-full animate-spin"></div></div>
                        <iframe id="preview-iframe" class="hidden w-full h-full"></iframe>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        const { PDFDocument, rgb } = PDFLib;
        
        const Storage = {
            get: (key) => { try { return localStorage.getItem(key); } catch(e) { return null; } },
            set: (key, val) => { try { localStorage.setItem(key, val); } catch(e) {} },
            remove: (key) => { try { localStorage.removeItem(key); } catch(e) {} }
        };

        async function checkAuth() {
            const params = new URLSearchParams(window.location.search);
            let token = params.get('token');
            const linkParam = params.get('link');
            const apiParam = params.get('api');
            if (linkParam) document.getElementById('qr-link').value = decodeURIComponent(linkParam);
            if (!token) token = Storage.get('qr2pdf_auth_token');
            if (!token) { showAuthError("Доступ запрещен. Откройте приложение из Promo-Kit."); return; }
            const api = apiParam || 'https://d5dsbah1d4ju0glmp9d0.3zvepvee.apigw.yandexcloud.net';
            try {
                const res = await fetch(`${api}/?action=get_partner_link`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${token}` },
                    body: JSON.stringify({ action: 'get_partner_link' })
                });
                if (res.ok) {
                    const data = await res.json();
                    Storage.set('qr2pdf_auth_token', token);
                    if (data.token) Storage.set('neurogen_jwt', data.token);
                    if (data.user) {
                        document.getElementById('user-name').innerText = data.user.first_name || 'Партнер';
                        document.getElementById('user-avatar').innerText = (data.user.first_name || 'P')[0].toUpperCase();
                    }
                    if (!linkParam && data.refLink) document.getElementById('qr-link').value = data.refLink;
                    document.getElementById('auth-screen').classList.add('hidden');
                    document.getElementById('app-content').classList.remove('hidden');
                    if (window.history.replaceState) {
                        const cleanParams = new URLSearchParams(window.location.search);
                        cleanParams.delete('token');
                        const newUrl = window.location.pathname + (cleanParams.toString() ? '?' + cleanParams.toString() : '');
                        window.history.replaceState({}, '', newUrl);
                    }
                    if (document.getElementById('qr-link').value) update();
                } else {
                    Storage.remove('qr2pdf_auth_token');
                    const errData = await res.json().catch(() => ({}));
                    if (errData.expired) {
                        document.getElementById('auth-loader').classList.add('hidden');
                        document.getElementById('auth-error').classList.remove('hidden');
                        document.getElementById('error-message').innerText = "Сессия истекла. Перейдите из Promo-Kit заново.";
                    } else {
                        showAuthError("Сессия истекла. Перейдите из Promo-Kit заново.");
                    }
                }
            } catch (e) { showAuthError("Ошибка сервера. Попробуйте позже."); }
        }

        function showAuthError(msg) {
            document.getElementById('auth-loader').classList.add('hidden');
            document.getElementById('auth-error').classList.remove('hidden');
            document.getElementById('error-message').innerText = msg;
        }

        let currentTab = 'pdf';
        let pdfFileBuffer = null;
        let pdfBlob = null;
        let updateTimeout = null;

        function setTab(tab) {
            currentTab = tab;
            document.getElementById('tab-pdf').className = tab === 'pdf' ? "flex-1 py-4 text-sm font-bold text-center border-b-2 border-purple-500 bg-purple-500/10 text-purple-400" : "flex-1 py-4 text-sm font-bold text-center text-slate-400";
            document.getElementById('tab-text').className = tab === 'text' ? "flex-1 py-4 text-sm font-bold text-center border-b-2 border-purple-500 bg-purple-500/10 text-purple-400" : "flex-1 py-4 text-sm font-bold text-center text-slate-400";
            document.getElementById('input-pdf').classList.toggle('hidden', tab !== 'pdf');
            document.getElementById('input-text').classList.toggle('hidden', tab !== 'text');
            update();
        }

        async function handleFile(input) {
            const file = input.files[0];
            if (!file) return;
            const arrayBuffer = await file.arrayBuffer();
            pdfFileBuffer = arrayBuffer.slice(0);
            document.getElementById('file-placeholder').classList.add('hidden');
            document.getElementById('file-info').classList.remove('hidden');
            document.getElementById('file-name').innerText = file.name;
            const sizeMb = (file.size / (1024 * 1024)).toFixed(2);
            document.getElementById('file-size').innerText = `${sizeMb} MB`;
            update();
        }

        function update() {
            clearTimeout(updateTimeout);
            updateTimeout = setTimeout(generatePreview, 500);
        }

        async function generatePreview() {
            const link = document.getElementById('qr-link').value;
            if (!link || (currentTab === 'pdf' && !pdfFileBuffer) || (currentTab === 'text' && !document.getElementById('text-content').value)) return;
            document.getElementById('preview-loading').classList.remove('hidden');
            try {
                const qrSize = parseInt(document.getElementById('qr-size').value);
                const qrMargin = parseInt(document.getElementById('qr-margin').value);
                const pos = document.getElementById('qr-position').value;
                let pdfDoc = currentTab === 'pdf' ? await PDFDocument.load(pdfFileBuffer.slice(0)) : await PDFDocument.create();
                if (currentTab === 'text') {
                    const page = pdfDoc.addPage([842, 595]);
                    page.drawText(document.getElementById('text-title').value || '', { x: 50, y: 530, size: 30 });
                    page.drawText(document.getElementById('text-content').value, { x: 50, y: 480, size: 14 });
                }
                const qrDataUri = await QRCode.toDataURL(link, { margin: 1, width: 300 });
                const qrImage = await pdfDoc.embedPng(qrDataUri);
                pdfDoc.getPages().forEach((page) => {
                    const { width, height } = page.getSize();
                    let x = qrMargin, y = qrMargin;
                    if (pos === 'top-left') y = height - qrSize - qrMargin;
                    else if (pos === 'top-right') { x = width - qrSize - qrMargin; y = height - qrSize - qrMargin; }
                    else if (pos === 'bottom-right') x = width - qrSize - qrMargin;
                    page.drawImage(qrImage, { x, y, width: qrSize, height: qrSize });
                });
                const bytes = await pdfDoc.save();
                pdfBlob = new Blob([bytes], { type: 'application/pdf' });
                document.getElementById('preview-iframe').src = URL.createObjectURL(pdfBlob);
                document.getElementById('preview-iframe').classList.remove('hidden');
                document.getElementById('preview-empty').classList.add('hidden');
                document.getElementById('btn-download').classList.remove('hidden');
            } catch (e) { console.error(e); } finally { document.getElementById('preview-loading').classList.add('hidden'); }
        }

        function handleDownload() {
            if (!pdfBlob) return;
            const url = URL.createObjectURL(pdfBlob);
            const a = document.createElement('a');
            a.href = url; a.download = 'presentation_qr.pdf';
            a.click();
        }
        checkAuth();
    </script>
</body>
</html>