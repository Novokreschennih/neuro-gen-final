                const img = cvs.toDataURL("image/png"); const d = BENEFITS[currentLinkMode];
                const w = window.open("", "_blank");
                w.document.write(`<!DOCTYPE html><html><head><title>Флаер</title><style>@page{size:A4 portrait;margin:0}*{box-sizing:border-box}body{font-family:Arial,sans-serif;margin:0;padding:0;background:#fff;width:210mm;height:297mm;overflow:hidden}.container{width:100%;height:100%;padding:15mm;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;border:8px solid #f0f0f0}.tag{background:#06b6d4;color:#fff;padding:4px 15px;border-radius:50px;font-weight:800;font-size:14px;text-transform:uppercase;margin-bottom:10mm}h1{font-size:32pt;text-transform:uppercase;margin:0 0 5mm 0;font-weight:900;line-height:1.1;color:#000}p.sub{font-size:18pt;color:#444;margin-bottom:12mm;line-height:1.3;max-width:160mm}.grid{display:grid;grid-template-columns:1fr 1fr;gap:8mm;width:100%;text-align:left;margin-bottom:15mm}.card{border-left:5px solid #06b6d4;padding:10px 15px;background:#f8f8f8;border-radius:0 12px 12px 0}.card h3{margin:0 0 5px 0;font-size:14pt;font-weight:800;color:#000}.card p{margin:0;font-size:11pt;color:#333;line-height:1.3}.qr-sec{width:100%;display:flex;flex-direction:column;align-items:center;margin-top:5mm}.qr-sec h3{margin-bottom:5mm;font-size:20pt;color:#000;font-weight:900;text-transform:uppercase}.qr-box{padding:15px;border:5px dashed #06b6d4;border-radius:25px;background:#fff}.qr-box img{width:60mm;height:60mm}</style></head><body><div class="container"><div class="tag">${d.tag}</div><h1>${d.pdfTitle}</h1><p class="sub">${d.subtitle}</p><div class="grid"><div class="card"><h3>${d.cards[0].title}</h3><p>${d.cards[0].text}</p></div><div class="card"><h3>${d.cards[1].title}</h3><p>${d.cards[1].text}</p></div><div class="card"><h3>${d.cards[2].title}</h3><p>${d.cards[2].text}</p></div><div class="card" style="border-color:#a855f7"><h3>${d.cards[3].title}</h3><p>${d.cards[3].text}</p></div></div><div class="qr-sec"><h3>Запусти систему здесь:</h3><div class="qr-box"><img src="${img}"/></div></div></div></body></html>`);
                w.document.close(); setTimeout(() => w.print(), 1000);
            }
        });

        document.getElementById("createPdfBtn").addEventListener("click", () => {
            window.open(`https://neuro-gen.ru/qr2pdf/?link=${encodeURIComponent(getActiveLink())}&token=${webAppJwt}`, "_blank");
        });

        // AI Writer
        async function generateAIPost() {
            const sel = document.getElementById("aiPostTopic"); const top = sel.options[sel.selectedIndex]?.text;
            const btn = document.getElementById("generatePostBtn"); const box = document.getElementById("aiPostResult"); const txt = document.getElementById("aiPostText");
            if(!sel.value) return showToast("Выберите аудиторию!", "warning");
            btn.disabled = true; const orig = btn.innerHTML; btn.innerHTML = "⏳ ГЕНЕРАЦИЯ...";
            try {
                const res = await fetch(`${BACKEND_URL}/?action=generate-post`, { method: "POST", headers: authHeaders, body: JSON.stringify({ action: "generate-post", topic: top, link: getActiveLink() }) });
                const d = await res.json();
                if(d.answer && !d.answer.includes("⚠️") && !d.answer.includes("⏳")) {
                    txt.innerHTML = d.answer.replace(/\n/g, "<br>"); box.classList.remove("hidden"); box.classList.add("animate-fadeInUp"); showToast("Готово!");
                } else throw new Error();
            } catch(e) {
                const p = STATIC_POSTS[sel.value] || STATIC_POSTS["Предприниматели, владельцы бизнеса"];
                txt.innerHTML = p[Math.floor(Math.random() * p.length)].replace("{link}", getActiveLink()).replace(/\n/g, "<br>");
                box.classList.remove("hidden"); box.classList.add("animate-fadeInUp"); showToast("Применён шаблон", "info");
            } finally { btn.disabled = false; btn.innerHTML = orig; }
        }

        // AI Config — модели и цены
        const CHAT_MODELS_PREFIXES = [
          "deepseek", "openai/gpt", "anthropic/claude", "google/gemini",
          "qwen", "mistralai", "meta-llama", "cohere/command",
        ];

        const FALLBACK_MODELS = {
          polza: [
            { id: "deepseek/deepseek-v4-flash", pricing: { prompt: 0, completion: 0 } },
            ],
          openrouter: [
            { id: "deepseek/deepseek-v4-flash", pricing: { prompt: 0, completion: 0 } },
            
          ],
        };

        function renderModels(sel, models, pre) {
          const key = document.getElementById("ai-api-key").value.trim();
          if (!key) {
            sel.innerHTML = '<option value="deepseek/deepseek-v4-flash">DeepSeek V4 Flash</option>';
            if (pre) sel.value = pre;
            return;
          }
          const provider = document.getElementById("ai-provider").value;
          let filtered = models;
          if (provider === "openrouter") {
            filtered = models.filter(m =>
              CHAT_MODELS_PREFIXES.some(p => m.id.startsWith(p))
            );
          }

          // Приводим pricing к единому формату
          filtered = filtered.map(m => {
            // Маппинг input/output → prompt/completion
            if (m.pricing) {
              if (m.pricing.input !== undefined && m.pricing.prompt === undefined) m.pricing.prompt = m.pricing.input;
              if (m.pricing.output !== undefined && m.pricing.completion === undefined) m.pricing.completion = m.pricing.output;
              // Парсим строки
              if (typeof m.pricing.prompt === 'string') m.pricing.prompt = parseFloat(m.pricing.prompt) || 0;
              if (typeof m.pricing.completion === 'string') m.pricing.completion = parseFloat(m.pricing.completion) || 0;
            }
            // Если после нормализации pricing нет или цены = 0 — подтягиваем из fallback
            if (!m.pricing || (!m.pricing.prompt && !m.pricing.completion)) {
              const fallback = FALLBACK_MODELS[provider].find(f => f.id === m.id);
              if (fallback) m.pricing = { ...fallback.pricing };
              else m.pricing = { prompt: 0, completion: 0 };
            }
            return m;
          });
          filtered = filtered.filter(m => {
            const p = (m.pricing?.prompt || 0) + (m.pricing?.completion || 0);
            return m.id && m.id !== "N/A";
          });
          filtered.sort((a, b) => {
            const aPrice = (a.pricing?.prompt || 0) + (a.pricing?.completion || 0);
            const bPrice = (b.pricing?.prompt || 0) + (b.pricing?.completion || 0);
            return aPrice - bPrice;
          });
          sel.innerHTML = filtered.map(m => {
            const pricePerM = ((m.pricing?.prompt || 0) + (m.pricing?.completion || 0)) * 1_000_000;
            const short = m.id.split("/").pop();
            const label = pricePerM === 0 ? `${short}` : `${short} \$${pricePerM < 0.01 ? pricePerM.toFixed(2) : pricePerM.toFixed(2)}/1M`;
            return `<option value="${m.id}">${label}</option>`;
          }).join("");
          if (pre && filtered.some(m => m.id === pre)) sel.value = pre;
        }

        async function updateModelsList(pre = null) {
          const key = document.getElementById("ai-api-key").value.trim();
          const provider = document.getElementById("ai-provider").value;
          const sel = document.getElementById("ai-model");
          const provEl = document.getElementById("ai-provider");

          // Блокируем/разблокируем выбор провайдера
          if (!key) {
            provEl.value = "polza";
            provEl.disabled = true;
            sel.innerHTML = '<option value="deepseek/deepseek-v4-flash">DeepSeek V4 Flash</option>';
            if (pre) sel.value = pre;
            return;
          }
          provEl.disabled = false;

          // sessionStorage cache (5 мин)
          const cacheKey = `models_${provider}`;
          const cached = sessionStorage.getItem(cacheKey);
          if (cached) {
            try {
              const { data, ts } = JSON.parse(cached);
              if (Date.now() - ts < 300_000) {
                renderModels(sel, data, pre);
                return;
              }
            } catch (e) {}
          }

          try {
            const url = provider === "polza"
              ? "https://polza.ai/api/v1/models"
              : "https://openrouter.ai/api/v1/models";
            const headers = { "Content-Type": "application/json" };
            if (provider === "polza") headers["Authorization"] = `Bearer ${key}`;

            const res = await fetch(url, { headers });
            const json = await res.json();
            const models = json.data || [];
            sessionStorage.setItem(cacheKey, JSON.stringify({ data: models, ts: Date.now() }));
            renderModels(sel, models, pre);
          } catch (e) {
            renderModels(sel, FALLBACK_MODELS[provider], pre);
          }
        }

        // Событие: ввод API-ключа обновляет список моделей + core info
        document.addEventListener("DOMContentLoaded", () => {
          const keyInput = document.getElementById("ai-api-key");
          if (keyInput) {
            keyInput.addEventListener("change", () => {
              const sel = document.getElementById("ai-model");
              const pre = sel?.value || null;
              updateModelsList(pre);
            });
            keyInput.addEventListener("paste", () => {
              setTimeout(() => {
                const sel = document.getElementById("ai-model");
                const pre = sel?.value || null;
                updateModelsList(pre);
              }, 50);
            });
            keyInput.addEventListener("input", () => {
              const hasKey = !!keyInput.value.trim();
              const aiUntil = parseInt(userData?.ai_active_until) || 0;
              const isSaas = aiUntil > Date.now();
              const isPro = userData?.bought_tripwire || false;
              updateCoreInfo(isSaas, isPro, hasKey);
              updateAiLimitDisplay(isSaas, isPro, hasKey);
            });
          }
          const provSelect = document.getElementById("ai-provider");
          if (provSelect) {
            provSelect.addEventListener("change", () => {
              updateModelsList(null);
            });
          }
        });

        function compilePrompt() {
            const r = document.getElementById("ui-role").value || "Консультант"; const t = document.getElementById("ui-tone").value; const g = document.getElementById("ui-goal").value;
            let f = `Ты — ${r}. Общайся в стиле: ${t}. Твоя цель: ${g}.`;
            document.getElementById("ai-prompt-hidden").value = f;
        }

        function applyAiPreset(t) {
            const p = { shark: ["Волк с Уолл-Стрит в крипте", "Агрессивный, давит на выгоду", "Продать PRO-статус"], mentor: ["Опытный наставник", "Мудрый, спокойный", "Помочь принять верное решение"], techie: ["AI-инженер", "Техничный, точный", "Показать техническое превосходство"], friend: ["Заботливый друг", "Эмпатичный, задает вопросы", "Убедить зарегистрироваться"], visionary: ["Визионер будущего", "Вдохновляющий, масштабный", "Продать идею трансформации"] };
            document.getElementById("ui-role").value = p[t][0]; document.getElementById("ui-tone").value = p[t][1]; document.getElementById("ui-goal").value = p[t][2];
            compilePrompt(); showToast("Конфигурация загружена");
        }

        async function saveAiSettings() {
            const btn = document.getElementById("saveAiBtn"); btn.disabled = true; const orig = btn.innerHTML; btn.innerHTML = "⏳ СОХРАНЕНИЕ...";
            try {
                const res = await fetch(`${BACKEND_URL}/?action=update_ai_settings`, { method: "POST", headers: authHeaders, body: JSON.stringify({ action: "update_ai_settings", custom_prompt: document.getElementById("ai-prompt-hidden").value, ai_provider: "polza", ai_model: "deepseek/deepseek-v4-flash", custom_api_key: document.getElementById("ai-api-key").value.trim(), ai_ui_state: { role: document.getElementById("ui-role").value, tone: document.getElementById("ui-tone").value, goal: document.getElementById("ui-goal").value } }) });
                if((await res.json()).success) {
                    if (!userData.ai_ui_state) userData.ai_ui_state = {};
                    userData.ai_ui_state.role = document.getElementById("ui-role").value;
                    userData.ai_ui_state.tone = document.getElementById("ui-tone").value;
                    userData.ai_ui_state.goal = document.getElementById("ui-goal").value;
                    const _apiKey = !!document.getElementById("ai-api-key").value.trim();
                    updateCoreInfo((parseInt(userData.ai_active_until)||0)>Date.now(), userData.bought_tripwire, _apiKey);
                    updateAiLimitDisplay((parseInt(userData.ai_active_until)||0)>Date.now(), userData.bought_tripwire, _apiKey);
                    showToast("Ядро обновлено");
                } else throw new Error();
            } catch(e) { showToast("Ошибка", "error"); } finally { btn.disabled = false; btn.innerHTML = orig; }
        }

        async function saveApiSettings() {
            const btn = document.getElementById("saveApiBtn"); btn.disabled = true; const orig = btn.innerHTML; btn.innerHTML = "⏳ СОХРАНЕНИЕ...";
            try {
                const res = await fetch(`${BACKEND_URL}/?action=update_ai_settings`, { method: "POST", headers: authHeaders, body: JSON.stringify({ action: "update_ai_settings", custom_prompt: document.getElementById("ai-prompt-hidden").value, ai_provider: document.getElementById("ai-provider").value, ai_model: document.getElementById("ai-model").value, custom_api_key: document.getElementById("ai-api-key").value.trim() }) });
                if((await res.json()).success) {
                    userData.ai_provider = document.getElementById("ai-provider").value;
                    userData.ai_model = document.getElementById("ai-model").value;
                    const _apiKey = !!document.getElementById("ai-api-key").value.trim();
                    updateCoreInfo((parseInt(userData.ai_active_until)||0)>Date.now(), userData.bought_tripwire, _apiKey);
                    updateAiLimitDisplay((parseInt(userData.ai_active_until)||0)>Date.now(), userData.bought_tripwire, _apiKey);
                    showToast("Настройки API сохранены");
                } else throw new Error();
            } catch(e) { showToast("Ошибка", "error"); } finally { btn.disabled = false; btn.innerHTML = orig; }
        }

        // Вспомогательная функция для безопасного добавления сообщений (DOM-XSS Prevention)
        function appendSafeMessage(area, text, isUser, isError = false) {
          const div = document.createElement("div");
          if (isUser) {
            div.className = "p-4 text-sm rounded-2xl max-w-[85%] bg-gradient-to-br from-cyan-600 to-blue-600 text-white self-end shadow-md";
            div.textContent = "Вы: " + text;
          } else if (isError) {
            div.className = "p-4 text-sm rounded-2xl max-w-[85%] bg-gray-800/80 text-red-400 self-start shadow-md";
            div.textContent = "⚠️ " + text;
          } else {
            div.className = "p-4 text-sm rounded-2xl max-w-[85%] bg-gray-800/80 text-gray-200 self-start shadow-md border border-white/5";
            // ИИ-ответ: можно использовать innerHTML, но с санитизацией
            const sanitized = (text || "Сбой связи.").replace(/<script\b[^<]*(?:(?!<\/script>)<[^<]*)*<\/script>/gi, '').replace(/\son\w+="[^"]*"/gi, '');
            div.innerHTML = "🤖 " + sanitized.replace(/\n/g, "<br>");
          }
          area.appendChild(div);
          area.scrollTop = area.scrollHeight;
        }

        async function sendTestMessage() {
            const inp = document.getElementById("testChatInput"); const txt = inp.value.trim(); if(!txt) return; inp.value = "";
            const area = document.getElementById("testChatArea");
            appendSafeMessage(area, txt, true);
            const btn = document.getElementById("testSendBtn"); btn.disabled = true;
            try {
                const res = await fetch(`${BACKEND_URL}/?action=web-chat`, { method: "POST", headers: authHeaders, body: JSON.stringify({ action: "web-chat", message: txt, partner_id: userData.partner_id, sessionId: currentSessionId }) });
                const d = await res.json();
                appendSafeMessage(area, d.answer, false);
            } catch(e) {
                appendSafeMessage(area, "Ошибка сети.", false, true);
            }
            finally { btn.disabled = false; }
        }

        window.addEventListener("DOMContentLoaded", initUser);
    </script>
</body>
</html>
