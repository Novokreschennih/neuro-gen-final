            // Stats
            document.getElementById("statClicks").textContent = parseInt(userData.clicks) || 0;
            document.getElementById("statLeads").textContent = parseInt(userData.referrals) || 0;
            document.getElementById("statEarnings").textContent = parseInt(userData.paid_referrals) || 0;

            // Empire Tab (Profile)
            if(userData.first_name) {
                document.getElementById("profAvatar").textContent = userData.first_name[0].toUpperCase();
                document.getElementById("profName").textContent = userData.first_name;
            }
            document.getElementById("profShId").textContent = userData.sh_user_id || "—";

            // Payment Link
            const xp = parseInt(userData.xp) || 0;
            const inviterId = userData.inviter_sh_id || "1123";
            const paymentUrl = `https://hubblepay.net/${xp >= 100 ? "103_97998" : "142_ee4e9"}&afid=${inviterId}`;
            
            // Tariffs
            if (userData.is_pro) {
                document.getElementById("tariff-pro-block").classList.remove("hidden");
                document.getElementById("tariff-free-block").classList.add("hidden");
            } else {
                document.getElementById("tariff-free-block").classList.remove("hidden");
                document.getElementById("tariff-pro-block").classList.add("hidden");
                document.getElementById("btn-upgrade-pro").href = paymentUrl;
                document.getElementById("profXpBar").style.width = Math.min(xp, 100) + "%";
                document.getElementById("profXpText").textContent = `${xp}/100 XP`;
            }

            // Hub Apps
            renderApps(userData.is_pro, webAppJwt);
            // Academy link
            document.getElementById("academyLink").href = `https://sethubble.ru/academy/?token=${webAppJwt}`;
            // Channels
            renderChannelStatuses();
            // Links
            setLinkMode('universal');

            // AI Status
            const isAiActive = (parseInt(userData.ai_active_until) || 0) > Date.now();
            if(isAiActive) {
                document.getElementById("ai-constructor").classList.remove("hidden");
                document.getElementById("ai-paywall").classList.add("hidden");
                const fDate = new Date(parseInt(userData.ai_active_until)).toLocaleDateString("ru-RU", { day: "numeric", month: "long" });
                document.getElementById("status-date").textContent = `Подписка до ${fDate}`;
            } else {
                document.getElementById("ai-constructor").classList.add("hidden");
                document.getElementById("ai-paywall").classList.remove("hidden");
                document.getElementById("btn-upgrade-ai").href = `https://hubblepay.net/${userData.ai_product_id || "150_3ca87"}&afid=${inviterId}`;
            }

            // AI Settings Load
            if (userData.ai_provider) document.getElementById("ai-provider").value = userData.ai_provider;
            updateModelsList(userData.ai_model);
            if (userData.custom_api_key) document.getElementById("ai-api-key").value = userData.custom_api_key;
            if (userData.ai_ui_state) {
                const state = userData.ai_ui_state;
                if (state.role) document.getElementById("ui-role").value = state.role;
                if (state.tone) document.getElementById("ui-tone").value = state.tone;
                if (state.goal) document.getElementById("ui-goal").value = state.goal;
            }
            compilePrompt();
        }

        // ==========================================
        // RENDERERS
        // ==========================================
        function renderApps(isPro, jwt) {
            const container = document.getElementById("hub-apps-container");
            const apps = [
                { id: "crm", icon: "👥", name: "CRM Клиентов", desc: "Управление базой и рассылки", url: "https://neuro-gen.ru/crm/" },
                { id: "viral", icon: "🎬", name: "Viral Video", desc: "Сценарии для Reels/Shorts", url: "https://neuro-gen.ru/viral/" },
                { id: "scenarios", icon: "🤖", name: "Bot Scenarios", desc: "Промпты для автоворонок", url: "https://neuro-gen.ru/scenarios/" },
                { id: "architect", icon: "🏗️", name: "Architect", desc: "Стратегии бизнеса", url: "https://neuro-gen.ru/architect/" }
            ];
            container.innerHTML = apps.map(a => {
                if (isPro) {
                    return `<button onclick="window.open('${a.url}?token=${jwt}', '_blank')" class="glass-panel p-6 rounded-[2rem] text-left flex flex-col justify-between h-full group hover:bg-white/5 transition-all border-t border-cyan-500/30">
                        <span class="text-4xl mb-4 group-hover:scale-110 transition-transform drop-shadow-lg">${a.icon}</span>
                        <div><h4 class="text-sm font-black text-white uppercase tracking-tight mb-1">${a.name}</h4><p class="text-[10px] text-gray-400 leading-tight">${a.desc}</p></div>
                    </button>`;
                } else {
                    return `<button onclick="showToast('💎 Доступно только на PRO!', 'error')" class="bg-black/40 border border-white/5 p-6 rounded-[2rem] text-left opacity-60 flex flex-col justify-between h-full group relative overflow-hidden">
                        <div class="absolute inset-0 bg-black/80 flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity z-10 backdrop-blur-sm"><span class="text-3xl">🔒</span></div>
                        <span class="text-4xl mb-4 grayscale filter">${a.icon}</span>
                        <div><h4 class="text-sm font-black text-gray-400 uppercase tracking-tight mb-1">${a.name}</h4><p class="text-[10px] text-gray-600 leading-tight">${a.desc}</p></div>
                    </button>`;
                }
            }).join('');
        }

        function renderChannelStatuses() {
            const container = document.getElementById("channelGrid");
            const ch = userData.channels || {};
            const meta = { telegram: { icon: "📱", name: "Telegram", fallback: true }, vk: { icon: "📢", name: "ВКонтакте", fallback: true }, web: { icon: "🌐", name: "Web-чат", fallback: true }, email: { icon: "📧", name: "Email", fallback: false } };

            container.innerHTML = Object.keys(meta).map(k => {
                const m = meta[k]; const isActive = ch[k]?.configured || m.fallback;
                return isActive ? `
                    <div class="bg-black/40 rounded-xl p-4 border border-white/5 flex items-center justify-between">
                        <div class="flex items-center gap-3"><span class="text-2xl">${m.icon}</span><div><p class="text-xs font-bold text-white">${m.name}</p><p class="text-[10px] text-green-400">Активен</p></div></div>
                        <span class="w-2.5 h-2.5 bg-green-500 rounded-full shadow-[0_0_8px_#22c55e]"></span>
                    </div>` : `
                    <div class="bg-black/20 rounded-xl p-4 border border-white/5 flex items-center justify-between opacity-50">
                        <div class="flex items-center gap-3"><span class="text-2xl grayscale">${m.icon}</span><div><p class="text-xs font-bold text-gray-500">${m.name}</p><p class="text-[10px] text-gray-600">Не подключен</p></div></div>
                        <span class="w-2.5 h-2.5 bg-gray-700 rounded-full"></span>
                    </div>`;
            }).join('');
        }

        // ==========================================
        // ACTIONS & LOGIC
        // ==========================================
        function getActiveLink() {
            const pId = userData?.partner_id || "p_qdr"; const pAfid = userData?.sh_user_id || "1123";
            const base = `https://neuro-gen.ru/?page=${pId}&afid=${pAfid}`;
            if (currentLinkMode === "online") return base + "&role=online";
            if (currentLinkMode === "offline") return base + "&role=b2b";
            if (currentLinkMode === "agent") return base + "&role=agent";
            return base + "&role=universal";
        }

        function setLinkMode(mode) {
            currentLinkMode = mode;
            ["universal", "agent", "online", "offline"].forEach(m => {
                const btn = document.getElementById(`m-${m}`);
                if (btn) btn.className = m === mode ? `mode-btn active` : "mode-btn";
            });

            const url = getActiveLink();
            document.getElementById("botLinkDisplay").textContent = url;
            const qr = document.getElementById("qrcode"); qr.innerHTML = "";
            try { new QRCode(qr, { text: url, width: 140, height: 140, colorDark: "#000", colorLight: "#fff", correctLevel: QRCode.CorrectLevel.H }); } catch(e){}

            // Update Info Tab
            const info = BENEFITS[mode];
            document.getElementById("about-tag").textContent = info.tag;
            document.getElementById("about-title").innerHTML = info.title;
            document.getElementById("about-subtitle").textContent = info.subtitle;
            document.getElementById("about-cards").innerHTML = info.cards.map((c, i) => `
                <div class="glass-panel p-6 rounded-[2rem] transition-all hover:bg-white/5 ${i===3?'border-t border-purple-500/30':'border-t border-cyan-500/30'}">
                    <span class="text-4xl block mb-4">${c.icon}</span>
                    <h3 class="text-sm font-black text-white uppercase tracking-wide mb-2">${c.title}</h3>
                    <p class="text-[11px] text-gray-400 leading-relaxed">${c.text}</p>
                </div>
            `).join('');
            
            if (tg?.HapticFeedback) tg.HapticFeedback.selectionChanged();
        }

        function copyToClipboard(id, isText = false) {
            const t = isText ? id : document.getElementById(id).textContent;
            navigator.clipboard.writeText(t).then(() => showToast("Скопировано!"));
        }

        document.getElementById("printTableTentBtn").addEventListener("click", () => {
            const cvs = document.getElementById("qrcode").querySelector("canvas");
            if(cvs) {
                const img = cvs.toDataURL("image/png"); const d = BENEFITS[currentLinkMode];
                const w = window.open("", "_blank");
                w.document.write(`<!DOCTYPE html><html><head><title>Флаер</title><style>@page{size:A4 portrait;margin:0}*{box-sizing:border-box}body{font-family:Arial,sans-serif;margin:0;padding:0;background:#fff;width:210mm;height:297mm;overflow:hidden}.container{width:100%;height:100%;padding:15mm;display:flex;flex-direction:column;align-items:center;justify-content:center;text-align:center;border:8px solid #f0f0f0}.tag{background:#06b6d4;color:#fff;padding:4px 15px;border-radius:50px;font-weight:800;font-size:14px;text-transform:uppercase;margin-bottom:10mm}h1{font-size:32pt;text-transform:uppercase;margin:0 0 5mm 0;font-weight:900;line-height:1.1;color:#000}p.sub{font-size:18pt;color:#444;margin-bottom:12mm;line-height:1.3;max-width:160mm}.grid{display:grid;grid-template-columns:1fr 1fr;gap:8mm;width:100%;text-align:left;margin-bottom:15mm}.card{border-left:5px solid #06b6d4;padding:10px 15px;background:#f8f8f8;border-radius:0 12px 12px 0}.card h3{margin:0 0 5px 0;font-size:14pt;font-weight:800;color:#000}.card p{margin:0;font-size:11pt;color:#333;line-height:1.3}.qr-sec{width:100%;display:flex;flex-direction:column;align-items:center;margin-top:5mm}.qr-sec h3{margin-bottom:5mm;font-size:20pt;color:#000;font-weight:900;text-transform:uppercase}.qr-box{padding:15px;border:5px dashed #06b6d4;border-radius:25px;background:#fff}.qr-box img{width:60mm;height:60mm}</style></head><body><div class="container"><div class="tag">${d.tag}</div><h1>${d.pdfTitle}</h1><p class="sub">${d.subtitle}</p><div class="grid"><div class="card"><h3>${d.cards[0].title}</h3><p>${d.cards[0].text}</p></div><div class="card"><h3>${d.cards[1].title}</h3><p>${d.cards[1].text}</p></div><div class="card"><h3>${d.cards[2].title}</h3><p>${d.cards[2].text}</p></div><div class="card" style="border-color:#a855f7"><h3>${d.cards[3].title}</h3><p>${d.cards[3].text}</p></div></div><div class="qr-sec"><h3>Запусти систему здесь:</h3><div class="qr-box"><img src="${img}"/></div></div></div></body></html>`);
                w.document.close(); setTimeout(() => w.print(), 1000);
            }
        });

        document.getElementById("createPdfBtn").addEventListener("click", () => {
            window.open(`https://neuro-gen.ru/qr2pdf/?link=${encodeURIComponent(getActiveLink())}&token=${webAppJwt}`, "_blank");
        });

        // AI Writer
        async function generateAIPost() {
            const sel = document.getElementById("aiPostTopic"); const top = sel.options[sel.selectedIndex]?.text;
            const btn = document.getElementById("generatePostBtn"); const box = document.getElementById("aiPostResult"); const txt = document.getElementById("aiPostText");
            if(!sel.value) return showToast("Выберите аудиторию!", "warning");
            btn.disabled = true; const orig = btn.innerHTML; btn.innerHTML = "⏳ ГЕНЕРАЦИЯ...";
            try {
                const res = await fetch(`${BACKEND_URL}/?action=generate-post`, { method: "POST", headers: authHeaders, body: JSON.stringify({ action: "generate-post", topic: top, link: getActiveLink() }) });
                const d = await res.json();
                if(d.answer && !d.answer.includes("⚠️") && !d.answer.includes("⏳")) {
                    txt.innerHTML = d.answer.replace(/\n/g, "<br>"); box.classList.remove("hidden"); box.classList.add("animate-fadeInUp"); showToast("Готово!");
                } else throw new Error();
            } catch(e) {
                const p = STATIC_POSTS[sel.value] || STATIC_POSTS["Предприниматели, владельцы бизнеса"];
                txt.innerHTML = p[Math.floor(Math.random() * p.length)].replace("{link}", getActiveLink()).replace(/\n/g, "<br>");
                box.classList.remove("hidden"); box.classList.add("animate-fadeInUp"); showToast("Применён шаблон", "info");
            } finally { btn.disabled = false; btn.innerHTML = orig; }
        }

        // AI Config
        const MODELS = { polza: ["openai/gpt-4o-mini", "deepseek/deepseek-v4-flash", "anthropic/claude-3.5-sonnet"], openrouter: ["openai/gpt-4o-mini", "deepseek/deepseek-v4-flash", "anthropic/claude-3.5-sonnet", "openai/gpt-4o"] };
        function updateModelsList(pre = null) {
            const p = document.getElementById("ai-provider").value; const s = document.getElementById("ai-model"); s.innerHTML = "";
            MODELS[p].forEach(m => { const o = document.createElement("option"); o.value = m; o.textContent = m.split('/').pop(); s.appendChild(o); });
            if(pre) s.value = pre;
        }

        function compilePrompt() {
            const r = document.getElementById("ui-role").value || "Консультант"; const t = document.getElementById("ui-tone").value; const g = document.getElementById("ui-goal").value;
            let f = `Ты — ${r}. Общайся в стиле: ${t}. Твоя цель: ${g}.`;
            document.getElementById("ai-prompt-hidden").value = f;
        }

        function applyAiPreset(t) {
            const p = { shark: ["Волк с Уолл-Стрит в крипте", "Агрессивный, давит на выгоду", "Продать PRO-статус"], mentor: ["Опытный наставник", "Мудрый, спокойный", "Помочь принять верное решение"], techie: ["AI-инженер", "Техничный, точный", "Показать техническое превосходство"], friend: ["Заботливый друг", "Эмпатичный, задает вопросы", "Убедить зарегистрироваться"], visionary: ["Визионер будущего", "Вдохновляющий, масштабный", "Продать идею трансформации"] };
            document.getElementById("ui-role").value = p[t][0]; document.getElementById("ui-tone").value = p[t][1]; document.getElementById("ui-goal").value = p[t][2];
            compilePrompt(); showToast("Конфигурация загружена");
        }

        async function saveAiSettings() {
            const btn = document.getElementById("saveAiBtn"); btn.disabled = true; const orig = btn.innerHTML; btn.innerHTML = "⏳ СОХРАНЕНИЕ...";
            try {
                const res = await fetch(`${BACKEND_URL}/?action=update_ai_settings`, { method: "POST", headers: authHeaders, body: JSON.stringify({ action: "update_ai_settings", custom_prompt: document.getElementById("ai-prompt-hidden").value, ai_provider: document.getElementById("ai-provider").value, ai_model: document.getElementById("ai-model").value, custom_api_key: document.getElementById("ai-api-key").value.trim(), ai_ui_state: { role: document.getElementById("ui-role").value, tone: document.getElementById("ui-tone").value, goal: document.getElementById("ui-goal").value } }) });
                if((await res.json()).success) showToast("Ядро обновлено"); else throw new Error();
            } catch(e) { showToast("Ошибка", "error"); } finally { btn.disabled = false; btn.innerHTML = orig; }
        }

        async function sendTestMessage() {
            const inp = document.getElementById("testChatInput"); const txt = inp.value.trim(); if(!txt) return; inp.value = "";
            const area = document.getElementById("testChatArea");
            area.insertAdjacentHTML("beforeend", `<div class="p-4 text-sm rounded-2xl max-w-[85%] bg-gradient-to-br from-cyan-600 to-blue-600 text-white self-end shadow-md">Вы: ${txt}</div>`);
            area.scrollTop = area.scrollHeight;
            const btn = document.getElementById("testSendBtn"); btn.disabled = true;
            try {
                const res = await fetch(`${BACKEND_URL}/?action=web-chat`, { method: "POST", headers: authHeaders, body: JSON.stringify({ action: "web-chat", message: txt, partner_id: userData.partner_id, sessionId: currentSessionId }) });
                const d = await res.json();
                area.insertAdjacentHTML("beforeend", `<div class="p-4 text-sm rounded-2xl max-w-[85%] bg-gray-800/80 text-gray-200 self-start shadow-md border border-white/5">🤖 ${d.answer || 'Сбой связи.'}</div>`);
            } catch(e) { area.insertAdjacentHTML("beforeend", `<div class="p-4 text-sm rounded-2xl max-w-[85%] bg-gray-800/80 text-red-400 self-start">⚠️ Ошибка.</div>`); }
            finally { btn.disabled = false; area.scrollTop = area.scrollHeight; }
        }

        window.addEventListener("DOMContentLoaded", initUser);
    </script>
</body>
</html>