        function renderPosts() {
            const container = document.getElementById("postsContainer");
            const filter = document.getElementById("aiPostTopic").value;
            const link = getActiveLink();

            let posts = [];
            if (filter === "all") {
                Object.keys(STATIC_POSTS).forEach(topic => {
                    STATIC_POSTS[topic].forEach((text, idx) => {
                        posts.push({ topic, text: text.replace("{link}", link), idx });
                    });
                });
            } else {
                const topicPosts = STATIC_POSTS[filter] || [];
                topicPosts.forEach((text, idx) => {
                    posts.push({ topic: filter, text: text.replace("{link}", link), idx });
                });
            }

            if (posts.length === 0) {
                container.innerHTML = `<div class="text-center text-gray-500 text-sm py-8">Нет постов для выбранной аудитории</div>`;
                return;
            }

            container.innerHTML = posts.map((p, i) => `
                <div class="bg-[#0a0a0f] rounded-xl border border-white/5 p-4 relative group cursor-pointer hover:border-cyan-500/30 transition-colors" onclick="copyPostText(${i})">
                    <div class="flex items-center justify-between mb-2">
                        <span class="text-[9px] font-bold text-gray-500 uppercase tracking-wider truncate max-w-[70%]">${p.topic}</span>
                        <span class="text-[9px] font-bold text-cyan-500/60">#${p.idx + 1}</span>
                    </div>
                    <p class="text-xs text-gray-300 leading-relaxed whitespace-pre-line line-clamp-4">${p.text}</p>
                    <div class="absolute top-2 right-2 p-1.5 bg-white/5 rounded-lg opacity-0 group-hover:opacity-100 transition-opacity">
                        <span class="text-xs">📋</span>
                    </div>
                </div>
            `).join('');

            // Store rendered posts for copy
            window._renderedPosts = posts;
        }

        function copyPostText(index) {
            const posts = window._renderedPosts || [];
            if (posts[index]) {
                navigator.clipboard.writeText(posts[index].text).then(() => showToast("Пост скопирован!"));
            }
        }

